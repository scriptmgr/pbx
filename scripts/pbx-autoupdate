#!/usr/bin/env bash
# shellcheck shell=bash
# - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version           :  202605191156-git
# @@Author           :  Jason Hempstead
# @@Contact          :  git-admin@casjaysdev.pro
# @@License          :  MIT or LICENSE.md
# @@ReadME           :  pbx-autoupdate --help | README.md
# @@Copyright        :  Copyright: (c) 2026 Jason Hempstead, Casjays Developments
# @@Created          :  Tuesday, May 19, 2026 11:56 EDT
# @@File             :  pbx-autoupdate
# @@Description      :  FreePBX weekly auto-update with pre-update database backup.
# @@Changelog        :  Add compliant script header; fix convention violations
# @@TODO             :
# @@Other            :
# @@Resource         :
# @@Terminal App     :  no
# @@sudo/root        :  yes
# @@Template         :  shell/bash
# - - - - - - - - - - - - - - - - - - - - - - - - -
# shellcheck disable=SC1001,SC1003,SC2001,SC2003,SC2016,SC2031,SC2090,SC2115,SC2120,SC2155,SC2199,SC2229,SC2317,SC2329
# - - - - - - - - - - - - - - - - - - - - - - - - -
VERSION="202605191156-git"
APPNAME="${0##*/}"
RUN_USER="${USER}"
SET_UID="${UID}"
SCRIPT_SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
set -euo pipefail

# /etc/cron.d entries run with a minimal PATH (/usr/bin:/bin) on most distros.
# fwconsole lives in /usr/sbin (RHEL) or /usr/local/sbin — extend PATH so
# `command -v fwconsole` works regardless of the invocation environment.
PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin${PATH:+:$PATH}"
export PATH

case "${1:-}" in
    --version|-V) printf "%s v%s\n" "$(basename "$0")" "${VERSION}"; exit 0 ;;
esac

if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
    RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
else
    RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"
    YELLOW="$(printf '\033[1;33m')"; BLUE="$(printf '\033[0;34m')"
    CYAN="$(printf '\033[0;36m')"; BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
fi
ok()   { printf "${GREEN}%s${NC}\n"   "$*"; }
info() { printf "${BLUE}%s${NC}\n"    "$*"; }
warn() { printf "${YELLOW}%s${NC}\n"  "$*"; }
err()  { printf "${RED}%s${NC}\n"     "$*" >&2; }
hdr()  { printf "\n${BOLD}%s${NC}\n" "$*"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ -z "${MYSQL_ROOT_PASSWORD_FILE:-}" ] && MYSQL_ROOT_PASSWORD_FILE="/etc/pbx/mysql_root_password"
[ -z "${MYSQL_ROOT_PASSWORD:-}" ] && [ -f "${MYSQL_ROOT_PASSWORD_FILE}" ] && \
    MYSQL_ROOT_PASSWORD=$(tr -d '\r\n' < "${MYSQL_ROOT_PASSWORD_FILE}" 2>/dev/null)
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

LOG=/var/log/pbx/autoupdate.log
BKDIR=/mnt/backups/pbx/database
RETAIN_DAYS="${AUTOUPDATE_RETAIN_DAYS:-28}"

mkdir -p "$(dirname "$LOG")" "$BKDIR"

__log_raw() { printf "%s\n" "$*" | sed 's/\x1b\[[0-9;]*m//g' >> "${LOG}"; }

usage() {
    printf "Usage: pbx-autoupdate [--dry-run]\n\n"
    printf "Weekly auto-update: DB backup then FreePBX module upgrade.\n\n"
    printf "Options:\n"
    printf "  --dry-run    Show what would be done without making changes\n"
    printf "  --help (alias: -h)    Show help
  --version (alias: -V)  Show version\n"
    exit 0
}

DRY_RUN=0
case "${1:-}" in --help|-h) usage ;; --dry-run) DRY_RUN=1 ;; esac

DATE=$(date +%Y%m%d-%H%M%S)
__log_raw "=== Auto-update started: $(date) ==="

hdr "Pre-update database backup"
DB_BACKUP="${BKDIR}/pre-update-${DATE}.sql.gz"

if [ "$DRY_RUN" -eq 1 ]; then
    info "DRY-RUN: Would dump all databases to ${DB_BACKUP}"
else
    command -v mysqldump >/dev/null 2>&1 || {
        err "mysqldump not found"
        __log_raw "ERROR: mysqldump not found"
        exit 1
    }
    MOPTS=""
    [ -n "${MYSQL_ROOT_PASSWORD:-}" ] && MOPTS="-p${MYSQL_ROOT_PASSWORD}"
    # shellcheck disable=SC2086
    if mysqldump -u root $MOPTS --all-databases 2>/dev/null | gzip > "$DB_BACKUP"; then
        ok "DB backup: ${DB_BACKUP}"
        __log_raw "DB backup OK: ${DB_BACKUP}"
        sha256sum "$DB_BACKUP" > "${DB_BACKUP}.sha256" 2>/dev/null || true
    else
        err "DB backup FAILED — skipping module update"
        __log_raw "ERROR: DB backup FAILED — skipping update"
        exit 1
    fi
fi

hdr "FreePBX module upgrade"
if command -v fwconsole >/dev/null 2>&1; then
    if [ "$DRY_RUN" -eq 1 ]; then
        info "DRY-RUN: Would run: fwconsole ma upgradeall --autoenable"
    else
        __log_raw "Running: fwconsole chown"
        fwconsole chown --quiet 2>/dev/null || true
        __log_raw "Running: fwconsole ma upgradeall --autoenable"
        if fwconsole ma upgradeall --autoenable 2>&1 \
                | sed 's/\x1b\[[0-9;]*m//g' >> "$LOG"; then
            ok "FreePBX modules upgraded"
            __log_raw "Module upgrade complete"
        else
            warn "Module upgrade had warnings (see log)"
            __log_raw "WARNING: module upgrade had non-zero exit"
        fi
        fwconsole reload --quiet 2>/dev/null || true
        __log_raw "fwconsole reload complete"
    fi
else
    warn "fwconsole not found — skipping module update"
    __log_raw "WARNING: fwconsole not found"
fi

hdr "Cleanup old backups (retain ${RETAIN_DAYS} days)"
if [ "$DRY_RUN" -eq 1 ]; then
    info "DRY-RUN: Would delete backups older than ${RETAIN_DAYS} days"
else
    find "$BKDIR" -name "pre-update-*.sql.gz"        -mtime "+${RETAIN_DAYS}" -delete 2>/dev/null || true
    find "$BKDIR" -name "pre-update-*.sql.gz.sha256" -mtime "+${RETAIN_DAYS}" -delete 2>/dev/null || true
    ok "Old backups cleaned"
fi

__log_raw "=== Auto-update complete: $(date) ==="
ok "Auto-update complete"
# ex: ts=2 sw=2 et filetype=sh
