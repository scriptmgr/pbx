#!/bin/bash
# pbxstatus — Adaptive PBX status dashboard
set -euo pipefail

SCRIPT_VERSION="${SCRIPT_VERSION:-3.0}"
case "${1:-}" in
    --version|-V)
        printf "%s v%s\n" "$(basename "$0")" "${SCRIPT_VERSION}"
        exit 0
        ;;
esac

if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
    RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
else
    RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"
    YELLOW="$(printf '\033[1;33m')"; BLUE="$(printf '\033[0;34m')"
    CYAN="$(printf '\033[0;36m')"; BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
fi

usage() {
    printf "Usage: pbxstatus [--compact|--wide] [--watch [seconds]] [--help] [--version]\n\n"
    printf "Adaptive PBX status dashboard for SSH, mobile terminals, and larger screens.\n\n"
    printf "Modes:\n"
    printf "  auto      Default. Picks compact, standard, or wide layout from terminal size\n"
    printf "  compact   Force the smallest layout for thin SSH sessions\n"
    printf "  wide      Force the wide dashboard layout for larger terminals\n"
    printf "  watch     Refresh continuously; press q to quit when running in a TTY\n\n"
    printf "Displays:\n"
    printf "  - Core service health (Asterisk, FreePBX, database, web, fax, fail2ban)\n"
    printf "  - Versions, calls, endpoints, load, RAM, disk, uptime\n"
    printf "  - Preferred PBX access URLs using server FQDN when available\n\n"
    printf "Options:\n"
    printf "  --compact              Force compact layout\n"
    printf "  --wide                 Force wide layout\n"
    printf "  --watch [seconds]      Refresh every N seconds (default: 5)\n"
    printf "  --help (alias: -h)     Show help\n"
    printf "  --version (alias: -V)  Show version\n"
    exit 0
}

MODE="auto"
WATCH_INTERVAL=""
while [ $# -gt 0 ]; do
    case "$1" in
        --help|-h) usage ;;
        --compact) MODE="compact" ;;
        --wide) MODE="wide" ;;
        --watch)
            MODE="watch"
            if [ $# -gt 1 ] && [[ "${2:-}" =~ ^[0-9]+$ ]]; then
                WATCH_INTERVAL="$2"
                shift
            fi
            ;;
        *)
            printf "%sUnknown option: %s%s\n" "${RED}" "$1" "${NC}" >&2
            usage
            ;;
    esac
    shift
done
[ -z "${WATCH_INTERVAL}" ] && WATCH_INTERVAL=5

set +u; [ -f /etc/pbx/.env ] && . /etc/pbx/.env 2>/dev/null; set -u

repeat_char() {
    local count="$1" ch="$2"
    [ "${count}" -le 0 ] && return 0
    printf "%${count}s" "" | tr ' ' "${ch}"
}

status_ok() { printf '%b' "${GREEN}OK${NC}"; }
status_bad() { printf '%b' "${RED}--${NC}"; }

service_state() {
    local s
    for s in "$@"; do
        systemctl is-active --quiet "${s}" 2>/dev/null && { status_ok; return; }
    done
    status_bad
}

safe_cols() {
    local c=""
    c=$(tput cols 2>/dev/null || true)
    [[ "${c:-}" =~ ^[0-9]+$ ]] || c=80
    [ "${c}" -lt 40 ] && c=40
    printf '%s' "${c}"
}

safe_lines() {
    local l=""
    l=$(tput lines 2>/dev/null || true)
    [[ "${l:-}" =~ ^[0-9]+$ ]] || l=24
    [ "${l}" -lt 10 ] && l=10
    printf '%s' "${l}"
}

collect_data() {
    TERM_COLS=$(safe_cols)
    TERM_LINES=$(safe_lines)

    PRIMARY_IP="${PRIMARY_IP:-$(ip -4 route get 8.8.8.8 2>/dev/null | awk '/src/{for(i=1;i<=NF;i++) if($i=="src"){print $(i+1); exit}}' || hostname -I 2>/dev/null | awk '{print $1}')}"
    FQDN=$(hostname -f 2>/dev/null || hostname)
    DISP="${FQDN:-${PRIMARY_IP:-unknown}}"
    HOST=$(hostname -s 2>/dev/null || hostname 2>/dev/null || printf 'pbx')
    SCHEME="http"
    [ -f /etc/asterisk/keys/asterisk.pem ] && SCHEME="https"

    AST_VER=$(asterisk -V 2>/dev/null | awk '{print $NF}' || echo "n/a")
    FPBX_VER=$(grep -oP '(?<=<version>)[^<]+' "${WEB_ROOT:-/var/www/apache/pbx}/admin/modules/framework/module.xml" 2>/dev/null | head -1 \
        || grep -oP '(?<=<version>)[^<]+' /var/www/html/admin/modules/framework/module.xml 2>/dev/null | head -1 \
        || timeout 3 fwconsole --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1 \
        || echo "n/a")
    PHP_VER=$(php -r "echo PHP_MAJOR_VERSION.'.'.PHP_MINOR_VERSION;" 2>/dev/null || echo "n/a")

    CALLS=$(timeout 3 asterisk -rx "core show channels count" 2>/dev/null \
        | awk '/active call/{print $1; found=1; exit} END{if(!found) print 0}')
    CALLS="${CALLS:-0}"
    PEERS=$(timeout 3 asterisk -rx "pjsip show endpoints" 2>/dev/null \
        | awk '/^[A-Za-z0-9][^ ]+ +(Not in use|In use|Unavail|Avail)/{c++} END{print c+0}')
    PEERS="${PEERS:-0}"

    AST_S=$(service_state asterisk)
    FPBX_S=$(service_state freepbx)
    DB_S=$(service_state mariadb mysql)
    WEB_S=$(service_state httpd apache2)
    FAX_S=$(service_state hylafax hfaxd)
    F2B_S=$(service_state fail2ban)

    MEM_TOTAL=$(awk '/MemTotal/{printf "%.1f", $2/1048576}' /proc/meminfo 2>/dev/null || echo "0.0")
    MEM_FREE=$(awk '/MemAvailable/{printf "%.1f", $2/1048576}' /proc/meminfo 2>/dev/null || echo "0.0")
    MEM_USED=$(awk "BEGIN{printf \"%.1f\", ${MEM_TOTAL:-0} - ${MEM_FREE:-0}}")
    DISK=$(df -h / 2>/dev/null | awk 'NR==2{print $3"/"$2" ("$5")"}' || echo "n/a")
    LOAD=$(cut -d' ' -f1-3 /proc/loadavg 2>/dev/null | tr ' ' '/' || echo "n/a")
    UPTIME_HR=$(awk '{printf "%.1fh", $1/3600}' /proc/uptime 2>/dev/null || echo "n/a")

    HOME_URL="${SCHEME}://${DISP}/"
    ADMIN_URL="${SCHEME}://${DISP}/admin/"
    UCP_URL="${SCHEME}://${DISP}/ucp/"
}

render_title() {
    local cols="$1" line
    line=$(repeat_char "${cols}" "=")
    printf "%b%s%b\n" "${BOLD}" "${line}" "${NC}"
    printf "%bPBX STATUS%b  %s  |  %s\n" "${BOLD}" "${NC}" "${HOST}" "${DISP}"
    printf "%b%s%b\n" "${BOLD}" "${line}" "${NC}"
}

render_compact() {
    render_title "${TERM_COLS}"
    printf "Asterisk %s  FreePBX %s  DB %s  Web %s\n" "${AST_S}" "${FPBX_S}" "${DB_S}" "${WEB_S}"
    printf "Fax %s  Fail2ban %s  Calls %s  Endpoints %s\n" "${FAX_S}" "${F2B_S}" "${CALLS}" "${PEERS}"
    printf "Asterisk %s  FreePBX %s  PHP %s\n" "${AST_VER}" "${FPBX_VER}" "${PHP_VER}"
    printf "Load %s  RAM %s/%sG  Disk %s\n" "${LOAD}" "${MEM_USED}" "${MEM_TOTAL}" "${DISK}"
    printf "Admin %s\n" "${ADMIN_URL}"
}

render_standard() {
    render_title "${TERM_COLS}"
    printf "%bServices%b\n" "${BOLD}" "${NC}"
    printf "  Asterisk  %s   FreePBX   %s   Database  %s\n" "${AST_S}" "${FPBX_S}" "${DB_S}"
    printf "  Web       %s   Fax       %s   Fail2ban  %s\n" "${WEB_S}" "${FAX_S}" "${F2B_S}"
    printf "\n%bRuntime%b\n" "${BOLD}" "${NC}"
    printf "  Calls %-6s Endpoints %-6s Load %s\n" "${CALLS}" "${PEERS}" "${LOAD}"
    printf "  RAM   %-6s/%sG  Disk %s  Uptime %s\n" "${MEM_USED}" "${MEM_TOTAL}" "${DISK}" "${UPTIME_HR}"
    printf "\n%bVersions%b\n" "${BOLD}" "${NC}"
    printf "  Asterisk %s  FreePBX %s  PHP %s\n" "${AST_VER}" "${FPBX_VER}" "${PHP_VER}"
    printf "\n%bAccess%b\n" "${BOLD}" "${NC}"
    printf "  Home  %s\n" "${HOME_URL}"
    printf "  Admin %s\n" "${ADMIN_URL}"
    printf "  UCP   %s\n" "${UCP_URL}"
}

render_wide() {
    local cols leftw rightw
    cols="${TERM_COLS}"
    leftw=$(( (cols - 6) / 2 ))
    rightw=$(( cols - leftw - 4 ))
    render_title "${cols}"
    printf "%-*s  %-*s\n" "${leftw}" "${BOLD}Services${NC}" "${rightw}" "${BOLD}Runtime${NC}"
    printf "%-*s  %-*s\n" "${leftw}" "Asterisk  ${AST_S}   FreePBX  ${FPBX_S}" "${rightw}" "Calls ${CALLS}   Endpoints ${PEERS}"
    printf "%-*s  %-*s\n" "${leftw}" "Database  ${DB_S}   Web      ${WEB_S}" "${rightw}" "Load ${LOAD}"
    printf "%-*s  %-*s\n" "${leftw}" "Fax       ${FAX_S}   Fail2ban ${F2B_S}" "${rightw}" "RAM ${MEM_USED}/${MEM_TOTAL}G   Disk ${DISK}"
    printf "%-*s  %-*s\n" "${leftw}" "" "${rightw}" "Uptime ${UPTIME_HR}"
    printf "\n%-*s  %-*s\n" "${leftw}" "${BOLD}Versions${NC}" "${rightw}" "${BOLD}Access${NC}"
    printf "%-*s  %-*s\n" "${leftw}" "Asterisk ${AST_VER}" "${rightw}" "Home  ${HOME_URL}"
    printf "%-*s  %-*s\n" "${leftw}" "FreePBX  ${FPBX_VER}" "${rightw}" "Admin ${ADMIN_URL}"
    printf "%-*s  %-*s\n" "${leftw}" "PHP      ${PHP_VER}" "${rightw}" "UCP   ${UCP_URL}"
}

render_once() {
    collect_data
    case "${MODE}" in
        compact)
            render_compact
            ;;
        wide)
            render_wide
            ;;
        watch|auto)
            if [ "${TERM_COLS}" -lt 60 ] || [ "${TERM_LINES}" -lt 14 ]; then
                render_compact
            elif [ "${TERM_COLS}" -ge 110 ] && [ "${TERM_LINES}" -ge 18 ]; then
                render_wide
            else
                render_standard
            fi
            ;;
    esac
}

watch_loop() {
    [ -t 1 ] || { render_once; return 0; }
    trap 'tput cnorm 2>/dev/null || true; printf "\n"; exit 0' INT TERM HUP
    tput civis 2>/dev/null || true
    while true; do
        clear
        render_once
        printf "\nPress q to quit • refresh %ss\n" "${WATCH_INTERVAL}"
        if read -r -s -n 1 -t "${WATCH_INTERVAL}" key 2>/dev/null; then
            [ "${key}" = "q" ] && break
        fi
    done
    tput cnorm 2>/dev/null || true
}

if [ "${MODE}" = "watch" ]; then
    watch_loop
else
    render_once
fi
