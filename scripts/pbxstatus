#!/bin/bash
# pbxstatus — Fast compact PBX status summary
set -euo pipefail

if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
    RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
    USE_EMOJI=0; SYM_OK="+"; SYM_FAIL="-"
else
    RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"
    YELLOW="$(printf '\033[1;33m')"; BLUE="$(printf '\033[0;34m')"
    CYAN="$(printf '\033[0;36m')"; BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
    USE_EMOJI=1; SYM_OK="OK"; SYM_FAIL="--"
fi

e() { [ "${USE_EMOJI:-0}" = "1" ] && printf "%s " "$1" || true; }
ok()   { printf "%s${GREEN}%s${NC}\n"   "$(e '+' )" "$*"; }
info() { printf "%s${BLUE}%s${NC}\n"    "$(e '>' )" "$*"; }
warn() { printf "%s${YELLOW}%s${NC}\n"  "$(e '!'  )" "$*"; }
err()  { printf "%s${RED}%s${NC}\n"     "$(e 'X' )" "$*" >&2; }
hdr()  { printf "\n${BOLD}%s${NC}\n"   "$*"; }

set +u; [ -f /etc/pbx/.env ] && . /etc/pbx/.env 2>/dev/null; set -u

usage() { printf "Usage: pbxstatus\nFast compact PBX status summary.\n"; exit 0; }
case "${1:-}" in --help|-h) usage;; esac

# Fast: no slow commands; use timeouts
IP=$(ip -4 route get 8.8.8.8 2>/dev/null | awk '/src/{for(i=1;i<=NF;i++) if($i=="src"){print $(i+1); exit}}' || hostname -I 2>/dev/null | awk '{print $1}')
FQDN=$(hostname -f 2>/dev/null || hostname)
DISP="${FQDN:-${IP}}"
HOST=$(hostname -s 2>/dev/null)

# Asterisk version (no socket needed)
AST_VER=$(asterisk -V 2>/dev/null | awk '{print $NF}' || echo "n/a")

# FreePBX version — read from module.xml, no PHP class loading
FPBX_VER=$(grep -oP '(?<=<version>)[^<]+' /var/www/html/admin/modules/framework/module.xml 2>/dev/null | head -1 \
           || timeout 3 fwconsole --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1 \
           || echo "n/a")

# PHP version
PHP_VER=$(php -r "echo PHP_MAJOR_VERSION.'.'.PHP_MINOR_VERSION;" 2>/dev/null || echo "n/a")

# Active calls (with timeout) — "core show channels count" outputs multiple lines; get the "active call(s)" line
CALLS=$(timeout 3 asterisk -rx "core show channels count" 2>/dev/null \
        | grep -iE 'active call' | grep -oE '^[0-9]+' | head -1 || echo "0")
CALLS="${CALLS:-0}"

# Registered endpoints (with timeout)
PEERS=$(timeout 3 asterisk -rx "pjsip show endpoints" 2>/dev/null \
        | grep -E "^[A-Za-z0-9][^ ]+ +(Not in use|In use|Unavail|Avail)" 2>/dev/null \
        | wc -l | tr -d ' ') || PEERS="0"
PEERS="${PEERS:-0}"
# Service status (fast)
svc_ok() {
    systemctl is-active --quiet "$1" 2>/dev/null \
        && printf '%b' "${GREEN}OK${NC}" \
        || printf '%b' "${RED}--${NC}"
}
svc_any() {
    for s in "$@"; do
        systemctl is-active --quiet "${s}" 2>/dev/null && printf '%b' "${GREEN}OK${NC}" && return
    done
    printf '%b' "${RED}--${NC}"
}

AST_S=$(svc_ok asterisk)
FPBX_S=$(svc_ok freepbx)
DB_S=$(svc_any mariadb mysql)
WEB_S=$(svc_any httpd apache2)
FAX_S=$(svc_any hylafax hfaxd)
F2B_S=$(svc_ok fail2ban)

# Resources from /proc (fast, no external commands)
MEM_TOTAL=$(awk '/MemTotal/{printf "%.1f", $2/1048576}' /proc/meminfo 2>/dev/null)
MEM_FREE=$(awk '/MemAvailable/{printf "%.1f", $2/1048576}' /proc/meminfo 2>/dev/null)
MEM_USED=$(awk "BEGIN{printf \"%.1f\", ${MEM_TOTAL:-0} - ${MEM_FREE:-0}}")
DISK=$(df -h / 2>/dev/null | awk 'NR==2{print $3"/"$2" ("$5")"}')
LOAD=$(cut -d' ' -f1-3 /proc/loadavg 2>/dev/null | tr ' ' '/')

LINE="=================================================="
printf "\n${BOLD}%s${NC}\n" "${LINE}"
printf "${BOLD}  PBX  %s  |  %s${NC}\n" "${HOST}" "${IP:-unknown}"
printf "${BOLD}%s${NC}\n" "${LINE}"
printf "  Asterisk ${CYAN}%-10s${NC}  FreePBX ${CYAN}%-10s${NC}  PHP ${CYAN}%s${NC}\n" "${AST_VER}" "${FPBX_VER}" "${PHP_VER}"
printf "  Calls: ${CYAN}%s${NC}  Endpoints: ${CYAN}%s${NC}\n\n" "${CALLS}" "${PEERS}"
printf "  asterisk[%b]  freepbx[%b]  db[%b]  web[%b]  fax[%b]  fail2ban[%b]\n" \
    "${AST_S}" "${FPBX_S}" "${DB_S}" "${WEB_S}" "${FAX_S}" "${F2B_S}"
printf "\n  CPU load: ${CYAN}%s${NC}  |  RAM: ${CYAN}%s/%sGB${NC}  |  Disk: ${CYAN}%s${NC}\n" \
    "${LOAD}" "${MEM_USED}" "${MEM_TOTAL}" "${DISK}"
printf "\n${BOLD}%s${NC}\n" "${LINE}"
printf "${BOLD}  http://%s/  |  http://%s/admin/${NC}\n" "${DISP}" "${DISP}"
printf "${BOLD}%s${NC}\n\n" "${LINE}"
