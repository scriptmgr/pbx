#!/bin/bash
set -euo pipefail
if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
    RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
else
    RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"
    YELLOW="$(printf '\033[1;33m')"; BLUE="$(printf '\033[0;34m')"
    CYAN="$(printf '\033[0;36m')"; BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
fi
ok()   { printf "${GREEN}%s${NC}\n"   "$*"; }
info() { printf "${BLUE}%s${NC}\n"    "$*"; }
warn() { printf "${YELLOW}%s${NC}\n"  "$*"; }
err()  { printf "${RED}%s${NC}\n"     "$*" >&2; }
hdr()  { printf "\n${BOLD}%s${NC}\n" "$*"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

usage() {
    printf "Usage: pbx-repair [--check|--deep]\n\nFreePBX repair sequence.\n\nOptions:\n"
    printf "  --check    Read-only status check (no restarts)\n"
    printf "  --deep     Also upgrade modules and check PHP syntax\n"
    printf "  --help/-h  Show help\n"; exit 0
}
DEEP=0; CHECK=0
case "${1:-}" in
    --help|-h)  usage ;;
    --check|--dry-run|--status) CHECK=1 ;;
    --deep)     DEEP=1 ;;
esac

# --check: read-only status report, no restarts
if [ "$CHECK" -eq 1 ]; then
    hdr "PBX Status Check (read-only)"
    for svc in asterisk httpd apache2 mariadb mysqld; do
        if command -v systemctl >/dev/null 2>&1; then
            if systemctl is-active --quiet "$svc" 2>/dev/null; then
                ok "Service $svc: running"
            elif systemctl list-unit-files "${svc}.service" &>/dev/null 2>&1; then
                warn "Service $svc: not running"
            fi
        fi
    done
    fwconsole ma list 2>/dev/null | grep -iE "broken|failed" && warn "Broken modules found" || ok "No broken FreePBX modules"
    if command -v asterisk >/dev/null 2>&1; then
        AMOD=$(asterisk -rx "module show" 2>/dev/null | tail -1)
        ok "Asterisk modules: $AMOD"
    fi
    ok "Status check complete"
    exit 0
fi

command -v fwconsole >/dev/null 2>&1 || { err "fwconsole not found"; exit 1; }

hdr "Refreshing module signatures"
fwconsole ma refreshsignatures 2>/dev/null && ok "Signatures refreshed" || warn "Warnings during signature refresh"

hdr "Fixing file permissions"
fwconsole chown 2>/dev/null && ok "Permissions fixed" || err "chown failed"

hdr "Reloading FreePBX"
fwconsole reload 2>/dev/null && ok "Reload successful" || warn "Reload warnings"

hdr "Restarting FreePBX"
fwconsole restart 2>/dev/null && ok "Restart successful" || err "Restart failed"

hdr "Reloading Asterisk core"
if command -v asterisk >/dev/null 2>&1; then
    timeout 10 asterisk -rx "core reload" 2>/dev/null && ok "Asterisk reloaded" || warn "Reload warnings"
fi

hdr "Checking for broken modules"
fwconsole ma list 2>/dev/null | grep -iE "broken|failed" || info "No broken modules found"

if [ "$DEEP" -eq 1 ]; then
    hdr "Upgrading all modules (--deep)"
    fwconsole ma upgradeall 2>/dev/null && ok "Modules upgraded" || warn "Module upgrade warnings"

    hdr "PHP syntax check (--deep)"
    FPBX_DIR="/var/www/html/admin"
    if [ -d "$FPBX_DIR" ] && command -v php >/dev/null 2>&1; then
        info "Scanning $FPBX_DIR for PHP syntax errors..."
        find "$FPBX_DIR" -name "*.php" -print0 | \
            xargs -0 -P4 php -l 2>&1 | grep -v "^No syntax errors" | grep -v "^$" \
            || info "No PHP syntax errors found"
    else
        warn "PHP or FreePBX admin directory not found"
    fi
fi
ok "Repair sequence complete"
