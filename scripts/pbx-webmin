#!/usr/bin/env bash
# shellcheck shell=bash
# - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version           :  202605191156-git
# @@Author           :  Jason Hempstead
# @@Contact          :  git-admin@casjaysdev.pro
# @@License          :  MIT or LICENSE.md
# @@ReadME           :  pbx-webmin --help | README.md
# @@Copyright        :  Copyright: (c) 2026 Jason Hempstead, Casjays Developments
# @@Created          :  Tuesday, May 19, 2026 11:56 EDT
# @@File             :  pbx-webmin
# @@Description      :  Webmin management for the PBX system
# @@Changelog        :  Add compliant script header; fix convention violations
# @@TODO             :
# @@Other            :
# @@Resource         :
# @@Terminal App     :  yes
# @@sudo/root        :  yes
# @@Template         :  shell/bash
# - - - - - - - - - - - - - - - - - - - - - - - - -
# shellcheck disable=SC1001,SC1003,SC2001,SC2003,SC2016,SC2031,SC2090,SC2115,SC2120,SC2155,SC2199,SC2229,SC2317,SC2329
# - - - - - - - - - - - - - - - - - - - - - - - - -
VERSION="202605191156-git"
APPNAME="${0##*/}"
RUN_USER="${USER}"
SET_UID="${UID}"
SCRIPT_SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
set -euo pipefail

case "${1:-}" in
    --version|-V) printf "%s v%s\n" "$(basename "$0")" "${VERSION}"; exit 0 ;;
esac
if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
    RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
else
    RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"
    YELLOW="$(printf '\033[1;33m')"; BLUE="$(printf '\033[0;34m')"
    CYAN="$(printf '\033[0;36m')"; BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
fi
ok()   { printf "${GREEN}%s${NC}\n"   "$*"; }
info() { printf "${BLUE}%s${NC}\n"    "$*"; }
warn() { printf "${YELLOW}%s${NC}\n"  "$*"; }
err()  { printf "${RED}%s${NC}\n"     "$*" >&2; }
hdr()  { printf "\n${BOLD}%s${NC}\n" "$*"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

WEBMIN_CONF="/etc/webmin/miniserv.conf"

usage() {
    printf "Usage: pbx-webmin [options]\n\nWebmin management.\n\nOptions:\n"
    printf "  (no args)         Show Webmin status\n"
    printf "  --restart         Restart Webmin\n"
    printf "  --update          Update Webmin package\n"
    printf "  --fix-modules     Prune to PBX-relevant modules\n"
    printf "  --add-user U P    Add Webmin user\n"
    printf "  --port PORT       Change Webmin port\n"
    printf "  --help (alias: -h)         Show help
  --version (alias: -V)  Show version\n"; exit 0
}

get_wm_port() {
    grep -- "^port=" "$WEBMIN_CONF" 2>/dev/null | cut -d= -f2 || echo "10000"
}

ALWAYS_KEEP="useradmin cron at proc software init bootup filesystems mount fdisk quota smart-status syslog logrotate time hostname shell net firewall webmin webminlog filemin updown custom man bandwidth"
CONDITIONAL="apache apache2 mysql mariadb postfix sshd fail2ban bind squid samba dovecot proftpd cups dhcpd spamassassin"

case "${1:-}" in
    --help|-h) usage ;;
    --restart)
        systemctl restart webmin 2>/dev/null && ok "Webmin restarted" || \
        service webmin restart 2>/dev/null   && ok "Webmin restarted" || \
        err "Could not restart Webmin" ;;
    --update)
        if command -v apt-get >/dev/null 2>&1; then
            apt-get install --only-upgrade webmin 2>/dev/null && ok "Webmin updated"
        elif command -v yum >/dev/null 2>&1; then
            yum update -y webmin 2>/dev/null && ok "Webmin updated"
        elif command -v dnf >/dev/null 2>&1; then
            dnf update -y webmin 2>/dev/null && ok "Webmin updated"
        else
            err "No package manager found"
        fi ;;
    --fix-modules)
        hdr "Pruning Webmin modules"
        WM_BASE="/usr/share/webmin"
        [ ! -d "$WM_BASE" ] && { err "Webmin not found at $WM_BASE"; exit 1; }
        KEEP_LIST=""
        for m in $ALWAYS_KEEP $CONDITIONAL; do KEEP_LIST="$KEEP_LIST $m"; done
        REMOVED=0
        for mod_dir in "${WM_BASE}"/*/; do
            mod=$(basename "$mod_dir")
            { [ "$mod" = "." ] || [ "$mod" = ".." ] || [ "$mod" = "acl" ]; } && continue
            FOUND=0
            for k in $KEEP_LIST; do [ "$k" = "$mod" ] && FOUND=1; done
            if [ "$FOUND" -eq 0 ]; then
                rm -rf "$mod_dir" 2>/dev/null && { info "  Removed module: $mod"; REMOVED=$((REMOVED+1)); }
            fi
        done
        ok "Pruned ${REMOVED} modules"
        systemctl restart webmin 2>/dev/null || service webmin restart 2>/dev/null || true ;;
    --add-user)
        USER="${2:-}"; PASS="${3:-}"
        [ -z "$USER" ] || [ -z "$PASS" ] && { err "--add-user requires USER and PASS"; exit 1; }
        if [ -x /usr/libexec/webmin/acl/add_user.pl ]; then
            /usr/libexec/webmin/acl/add_user.pl "$USER" "$PASS" / 2>/dev/null && ok "User $USER added"
        else
            HASH=$(openssl passwd -1 "$PASS" 2>/dev/null || printf '%s' "$PASS")
            printf "%s:%s:0:0:99999:7:::\n" "$USER" "$HASH" >> /etc/webmin/webmin.passwd 2>/dev/null \
                && ok "User $USER added to webmin.passwd" || err "Could not add user"
        fi ;;
    --port)
        PORT="${2:-}"; [ -z "$PORT" ] && { err "--port requires a PORT number"; exit 1; }
        [ -f "$WEBMIN_CONF" ] || { err "Webmin config not found: $WEBMIN_CONF"; exit 1; }
        sed -i "s/^port=.*/port=${PORT}/" "$WEBMIN_CONF"
        systemctl restart webmin 2>/dev/null || service webmin restart 2>/dev/null || true
        ok "Webmin port changed to ${PORT}" ;;
    *)
        hdr "Webmin Status"
        PORT=$(get_wm_port)
        FQDN=$(hostname -f 2>/dev/null || hostname)
        IP=$(ip -4 route get 8.8.8.8 2>/dev/null | awk '/src/{for(i=1;i<=NF;i++) if($i=="src"){print $(i+1); exit}}' || hostname -I 2>/dev/null | awk '{print $1}')
        DISP="${FQDN:-${IP}}"
        if systemctl is-active --quiet webmin 2>/dev/null || service webmin status >/dev/null 2>&1; then
            ok "Webmin is RUNNING on port ${PORT}"
            printf "  URL: https://%s:%s/\n" "${DISP}" "$PORT"
        else
            warn "Webmin is NOT running"
        fi ;;
esac
# ex: ts=2 sw=2 et filetype=sh
