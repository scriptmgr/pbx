#!/usr/bin/env bash
# pbx-status — PBX system status dashboard
set -euo pipefail

# ── Usage ──────────────────────────────────────────────────────────────────────
case "${1:-}" in
    --help|-h)
        printf 'Usage: pbx-status\n\nDisplay a formatted PBX system status dashboard.\n\nOptions:\n  --help, -h   Show this help\n'
        exit 0
        ;;
esac

# ── Root check ─────────────────────────────────────────────────────────────────
[ "$(id -u)" -ne 0 ] && { printf 'ERROR: Must run as root.\n' >&2; exit 1; }

# ── Colour setup ───────────────────────────────────────────────────────────────
if [ -z "${NO_COLOR+x}" ] && [ -t 1 ] && [ "${TERM:-dumb}" != "dumb" ] && [ "${CI:-}" != "true" ]; then
    RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'; BOLD=$'\033[1m'; NC=$'\033[0m'
else
    RED=''; GREEN=''; YELLOW=''; BOLD=''; NC=''
fi

# ── String / layout helpers ────────────────────────────────────────────────────
_repeat() {                           # _repeat CHAR N → repeated string
    local char="$1" n="$2" i=0 r=''
    while [ "$i" -lt "$n" ]; do r="${r}${char}"; i=$(( i + 1 )); done
    printf '%s' "$r"
}

_hr_bytes() {                         # _hr_bytes BYTES → human-readable size
    awk -v b="$1" 'BEGIN{
        if      (b >= 1073741824) printf "%.1fG", b / 1073741824
        else if (b >= 1048576)    printf "%.1fM", b / 1048576
        else if (b >= 1024)       printf "%.1fK", b / 1024
        else                      printf "%dB",   b
    }'
}

COL=16   # label column width
SRW=54   # section ruler inner width

section() { printf '\n  %s%s%s\n  %s\n' "$BOLD" "$1" "$NC" "$(_repeat '─' "$SRW")"; }
row()     { printf "  %-${COL}s %s\n" "$1" "$2"; }

# ── Service badge ──────────────────────────────────────────────────────────────
_badge() {
    case "$1" in
        active)  printf '%s[  OK  ]%s' "$GREEN"  "$NC" ;;
        failed)  printf '%s[ FAIL ]%s' "$RED"    "$NC" ;;
        *)       printf '%s[ STOP ]%s' "$YELLOW" "$NC" ;;
    esac
}

# Cache unit-file list once to avoid repeated systemctl calls
_UNITS=$(systemctl list-unit-files --type=service 2>/dev/null || true)

svc_row() {
    local svc="$1" extra="${2:-}" state installed=0
    state=$(systemctl is-active "$svc" 2>/dev/null || true)
    printf '%s\n' "$_UNITS" | grep -q "^${svc}\.service" && installed=1 || true
    # Skip silently if not installed and not running
    [ "$state" != "active" ] && [ "$installed" = "0" ] && return 0
    local badge; badge=$(_badge "$state")
    printf '  %-14s %s' "$svc" "$badge"
    [ -n "$extra" ] && printf '   %s' "$extra"
    printf '\n'
}

# ── Load environment ───────────────────────────────────────────────────────────
if [ -f /etc/pbx/.env ]; then
    set +u
    # shellcheck disable=SC1091
    . /etc/pbx/.env 2>/dev/null || true
    set -u
fi
PUBLIC_IP="${PUBLIC_IP:-}"

# Detect web-server service name
_web=''
for _s in "${APACHE_SERVICE:-}" apache2 httpd; do
    [ -z "$_s" ] && continue
    printf '%s\n' "$_UNITS" | grep -q "^${_s}\.service" && { _web="$_s"; break; } || true
done
[ -z "$_web" ] && _web='httpd'

# Detect PHP-FPM service name
_fpm='php-fpm'
for _s in php8.2-fpm php8.1-fpm php8.0-fpm php-fpm; do
    printf '%s\n' "$_UNITS" | grep -q "^${_s}\.service" && { _fpm="$_s"; break; } || true
done

# ── Gather system data ─────────────────────────────────────────────────────────
HOSTNAME_FQDN="$(hostname -f 2>/dev/null || hostname)"
DATE_STR="$(date '+%-d %b %Y')"
read -r LOAD_1 LOAD_5 LOAD_15 _ < /proc/loadavg

# Uptime
_secs="$(awk '{print int($1)}' /proc/uptime)"
_h=$(( _secs / 3600 )); _m=$(( (_secs % 3600) / 60 ))
if   [ "$_h" -ge 48 ]; then UPTIME_STR="$(( _h / 24 )) days, $(( _h % 24 )) hours"
elif [ "$_h" -ge  1 ]; then UPTIME_STR="${_h} hours, ${_m} minutes"
else                        UPTIME_STR="${_m} minutes"
fi

# Memory (from /proc/meminfo, values in kB)
_mtk=$(awk '/^MemTotal:/{print $2}'     /proc/meminfo)
_mak=$(awk '/^MemAvailable:/{print $2}' /proc/meminfo)
_muk=$(( _mtk - _mak ))
MEM_PCT=$(( _muk * 100 / _mtk ))
MEM_STR="$(_hr_bytes $(( _muk * 1024 ))) used / $(_hr_bytes $(( _mtk * 1024 ))) total (${MEM_PCT}%)"

# Disk (from df -B1 for exact byte counts)
read -r _ _dtot _duse _ _ _ < <(df -B1 / 2>/dev/null | awk 'NR==2')
DISK_PCT=$(( _duse * 100 / _dtot ))
DISK_STR="$(_hr_bytes "$_duse") used / $(_hr_bytes "$_dtot") total (${DISK_PCT}%)"

# IP addresses
PRIV_IP4=$(ip -4 route get 8.8.8.8 2>/dev/null \
    | awk 'NR==1{for(i=1;i<=NF;i++) if($i=="src") print $(i+1)}' || true)
PRIV_IP6=$(ip -6 route get 2001:4860:4860::8888 2>/dev/null \
    | awk '/src/{for(i=1;i<=NF;i++) if($i=="src") print $(i+1)}' \
    | head -1 2>/dev/null || true)
[ "${PRIV_IP6:-::1}" = "::1" ] && PRIV_IP6=''
if [ -z "$PUBLIC_IP" ]; then
    PUBLIC_IP=$(curl -s4 --max-time 5 https://ifconfig.me 2>/dev/null || true)
fi

# ── Asterisk data (all non-fatal) ─────────────────────────────────────────────
AST_VER='' CALLS=0 EP_CFG=0 EP_REG=0
if command -v asterisk >/dev/null 2>&1; then
    _av=$(timeout 5 asterisk -rx 'core show version' 2>/dev/null || true)
    AST_VER=$(printf '%s\n' "$_av" | grep -oE 'Asterisk [0-9]+\.[0-9]+\.[0-9]+' | head -1 || true)

    _ac=$(timeout 5 asterisk -rx 'core show channels count' 2>/dev/null || true)
    CALLS=$(printf '%s\n' "$_ac" | awk '/active call/{print $1; exit}')
    CALLS="${CALLS:-0}"

    _ae=$(timeout 5 asterisk -rx 'pjsip show endpoints' 2>/dev/null || true)
    EP_CFG=$(printf '%s\n' "$_ae" | awk '/^[ \t]+Endpoint:/{c++} END{print c+0}')
    EP_REG=$(printf '%s\n' "$_ae" | awk '/Avail/{c++} END{print c+0}')
fi

# ── Print dashboard ────────────────────────────────────────────────────────────
TITLE="PBX System Status  —  ${HOSTNAME_FQDN}  —  ${DATE_STR}"
HRULE="$(_repeat '═' $(( ${#TITLE} + 2 )))"

printf '\n%s\n  %s%s%s\n%s\n' "$HRULE" "$BOLD" "$TITLE" "$NC" "$HRULE"

# SYSTEM
section "SYSTEM"
row "Hostname"      "$HOSTNAME_FQDN"
row "Private IPv4"  "${PRIV_IP4:-unknown}"
[ -n "$PRIV_IP6" ]                                      && row "Private IPv6" "$PRIV_IP6"
[ -n "$PUBLIC_IP" ] && [ "$PUBLIC_IP" != "$PRIV_IP4" ] && row "Public IPv4"  "$PUBLIC_IP"
row "Uptime"        "$UPTIME_STR"
row "Load (1/5/15)" "${LOAD_1}  ${LOAD_5}  ${LOAD_15}"
row "Memory"        "$MEM_STR"
row "Disk (/)"      "$DISK_STR"

# SERVICES
section "SERVICES"
svc_row "asterisk"  "${AST_VER}"
svc_row "freepbx"
svc_row "mariadb"
svc_row "$_web"
svc_row "$_fpm"
svc_row "fail2ban"
svc_row "postfix"
svc_row "hylafax"
svc_row "tftpd-hpa"

# TELEPHONY
section "TELEPHONY"
if command -v asterisk >/dev/null 2>&1; then
    row "Active calls"  "$CALLS"
    row "SIP endpoints" "${EP_REG} registered / ${EP_CFG} configured"
else
    printf '  (asterisk not installed)\n'
fi

# WEB INTERFACES
section "WEB INTERFACES"
_disp="${HOSTNAME_FQDN:-${PUBLIC_IP:-${PRIV_IP4:-unknown}}}"
_scheme="http"
[ -f /etc/asterisk/keys/asterisk.pem ] && _scheme="https"
row "FreePBX Admin" "${_scheme}://${_disp}/admin/"
row "User Portal"   "${_scheme}://${_disp}/ucp/"
row "AvantFax"      "${_scheme}://${_disp}/avantfax/"
if printf '%s\n' "$_UNITS" | grep -q '^webmin\.service'; then
    row "Webmin" "https://${_disp}:9001/"
fi

# RECENT LOG ERRORS
section "RECENT LOG ERRORS  (last 5)"
_astlog="/var/log/asterisk/full"
if [ -f "$_astlog" ]; then
    _errs=$(grep -iE '\[ERROR\]' "$_astlog" 2>/dev/null | tail -5 || true)
    if [ -n "$_errs" ]; then
        printf '%s\n' "$_errs" | while IFS= read -r _line; do
            printf '  %s%s%s\n' "$RED" "$_line" "$NC"
        done
    else
        printf '  [none]\n'
    fi
else
    printf '  (log not found: %s)\n' "$_astlog"
fi

printf '\n'
