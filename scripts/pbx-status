#!/bin/bash
set -euo pipefail
setup_output() {
    if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
        RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
        USE_EMOJI=0
    else
        RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"; YELLOW="$(printf '\033[1;33m')"
        BLUE="$(printf '\033[0;34m')"; CYAN="$(printf '\033[0;36m')"
        BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
        USE_EMOJI=1
    fi
}
setup_output
e() { [ "$USE_EMOJI" = "1" ] && printf "%s " "$1" || true; }
ok()   { printf "%s${GREEN}%s${NC}\n" "$(e ✅)" "$*"; }
info() { printf "%s${BLUE}%s${NC}\n"  "$(e ℹ️ )" "$*"; }
warn() { printf "%s${YELLOW}%s${NC}\n" "$(e ⚠️ )" "$*"; }
err()  { printf "%s${RED}%s${NC}\n" "$(e ❌)" "$*" >&2; }
hdr()  { printf "\n${BOLD}%s%s${NC}\n" "$(e 🔧)" "$*"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ -f /root/.pbx_passwords ] && . /root/.pbx_passwords 2>/dev/null || true
WEB_ROOT="${WEB_ROOT:-/var/www/html}"
_web="${APACHE_SERVICE:-}"; [ -z "$_web" ] && { command -v apache2 >/dev/null 2>&1 && _web="apache2" || _web="httpd"; }
_fpm="${PHP_FPM_SERVICE:-}"; [ -z "$_fpm" ] && _fpm="php-fpm"
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

usage() { printf "Usage: pbx-status\nShow full PBX system status.\n"; exit 0; }
[ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ] && usage

svc_check() {
    local svc="$1" state
    if command -v systemctl >/dev/null 2>&1; then
        state=$(systemctl is-active "$svc" 2>/dev/null)
    else
        service "$svc" status >/dev/null 2>&1 && state="active" || state="inactive"
    fi
    if [ "$state" = "active" ]; then
        ok "  ${svc}: ACTIVE"
    elif systemctl list-unit-files --type=service 2>/dev/null | grep -q "^${svc}\.service" || \
         [ -f "/etc/init.d/${svc}" ]; then
        err "  ${svc}: ${state:-INACTIVE}"
    fi
}

hdr "System Resources"
printf "  Hostname : %s\n" "$(hostname)"
printf "  Uptime   : %s\n" "$(uptime -p 2>/dev/null || uptime)"
printf "  Load     : %s\n" "$(cut -d' ' -f1-3 /proc/loadavg)"
echo ""; info "Memory:"; free -h 2>/dev/null
echo ""; info "Disk:";   df -h / 2>/dev/null

hdr "Network"
PRIV_IP=$(hostname -I 2>/dev/null | awk '{print $1}')
printf "  Private IP : %s\n" "${PRIV_IP:-unknown}"
[ -n "${PUBLIC_IP:-}" ] && printf "  Public IP  : %s\n" "$PUBLIC_IP"

hdr "PBX Services"
for svc in asterisk freepbx mariadb "${_web}" "${_fpm}" fail2ban postfix hylafax; do
    svc_check "$svc"
done

hdr "Active Calls"
if command -v asterisk >/dev/null 2>&1; then
    timeout 5 asterisk -rx "core show channels" 2>/dev/null || warn "Asterisk not responding"
else
    warn "Asterisk not installed"
fi

hdr "SIP Endpoints"
if command -v asterisk >/dev/null 2>&1; then
    timeout 5 asterisk -rx "pjsip show endpoints" 2>/dev/null | head -30 || true
fi

hdr "Asterisk Version"
if command -v asterisk >/dev/null 2>&1; then
    timeout 5 asterisk -rx "core show version" 2>/dev/null || asterisk -V 2>/dev/null
fi

hdr "Recent Errors (last 5)"
ASTLOG="/var/log/asterisk/full"
if [ -f "$ASTLOG" ]; then
    grep -iE '\[ERROR\]|\[WARNING\]' "$ASTLOG" 2>/dev/null | tail -5 || info "No recent errors"
else
    warn "Log not found: $ASTLOG"
fi
