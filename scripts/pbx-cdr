#!/bin/bash
set -euo pipefail
if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
    RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
else
    RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"
    YELLOW="$(printf '\033[1;33m')"; BLUE="$(printf '\033[0;34m')"
    CYAN="$(printf '\033[0;36m')"; BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
fi
ok()   { printf "${GREEN}%s${NC}\n"   "$*"; }
info() { printf "${BLUE}%s${NC}\n"    "$*"; }
warn() { printf "${YELLOW}%s${NC}\n"  "$*"; }
err()  { printf "${RED}%s${NC}\n"     "$*" >&2; }
hdr()  { printf "\n${BOLD}%s${NC}\n" "$*"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

CDR_FILE="/var/log/asterisk/cdr-csv/Master.csv"
# CSV fields: accountcode,src,dst,dcontext,clid,channel,dstchannel,lastapp,lastdata,start,answer,end,duration,billsec,disposition,amaflags,uniqueid,userfield

usage() {
    printf "Usage: pbx-cdr [options]\n\nCall Detail Records management.\n\nOptions:\n"
    printf "  (no args)         Show last 20 calls\n"
    printf "  --today           Filter by today's date\n"
    printf "  --yesterday       Filter by yesterday's date\n"
    printf "  --search NUMBER   Search CDR for a phone number\n"
    printf "  --stats           Show call statistics summary\n"
    printf "  --export FILE     Export CDR to FILE.csv\n"
    printf "  --help/-h         Show help\n"; exit 0
}

check_cdr() {
    [ ! -f "$CDR_FILE" ] && { warn "CDR file not found: $CDR_FILE"; exit 0; }
}

print_header() {
    printf "%-12s %-15s %-15s %-20s %-8s %-12s\n" "Source" "Dest" "Context" "Start" "Dur(s)" "Status"
    printf "%s\n" "$(printf '─%.0s' {1..80})"
}

print_row() {
    IFS=, read -r acct src dst dctx clid chan dchan app data start ans end dur bill disp _rest <<< "$1"
    printf "%-12s %-15s %-15s %-20s %-8s %-12s\n" \
        "${src:-?}" "${dst:-?}" "${dctx:-?}" "${start:-?}" "${dur:-0}" "${disp:-?}"
}

case "${1:-}" in
    --help|-h) usage ;;
    --today)
        check_cdr
        TODAY=$(date +"%Y-%m-%d")
        hdr "Calls Today (${TODAY})"
        print_header
        grep "$TODAY" "$CDR_FILE" 2>/dev/null | tail -50 | while IFS= read -r line; do print_row "$line"; done ;;
    --yesterday)
        check_cdr
        YEST=$(date -d yesterday +"%Y-%m-%d" 2>/dev/null || date -v-1d +"%Y-%m-%d" 2>/dev/null)
        hdr "Calls Yesterday (${YEST})"
        print_header
        grep "${YEST}" "$CDR_FILE" 2>/dev/null | tail -50 | while IFS= read -r line; do print_row "$line"; done ;;
    --search)
        NUM="${2:-}"; [ -z "$NUM" ] && { err "--search requires a NUMBER"; exit 1; }
        check_cdr
        hdr "CDR Search: ${NUM}"
        print_header
        grep "$NUM" "$CDR_FILE" 2>/dev/null | tail -30 | while IFS= read -r line; do print_row "$line"; done ;;
    --stats)
        check_cdr
        hdr "CDR Statistics"
        TOTAL=$(wc -l < "$CDR_FILE" 2>/dev/null || echo 0)
        ANSWERED=$(grep -c "ANSWERED" "$CDR_FILE" 2>/dev/null || echo 0)
        FAILED=$(grep -c "FAILED\|NO ANSWER\|BUSY" "$CDR_FILE" 2>/dev/null || echo 0)
        printf "  Total calls     : %s\n" "$TOTAL"
        printf "  Answered        : %s\n" "$ANSWERED"
        printf "  Failed/No Ans   : %s\n" "$FAILED"
        info "Calls by hour (today):"
        TODAY=$(date +"%Y-%m-%d")
        grep "$TODAY" "$CDR_FILE" 2>/dev/null | cut -d, -f10 | cut -d' ' -f2 | cut -d: -f1 | \
            sort | uniq -c | sort -k2n | while read -r cnt hr; do
                printf "  Hour %s: %s calls\n" "$hr" "$cnt"
            done ;;
    --export)
        OUTFILE="${2:-}"
        [ -z "$OUTFILE" ] && { err "--export requires a FILE path"; exit 1; }
        check_cdr
        cp "$CDR_FILE" "$OUTFILE" && ok "CDR exported to: $OUTFILE ($(wc -l < "$OUTFILE") records)" \
            || err "Export failed" ;;
    *)
        check_cdr
        hdr "Last 20 Calls"
        print_header
        tail -20 "$CDR_FILE" 2>/dev/null | while IFS= read -r line; do print_row "$line"; done ;;
esac
