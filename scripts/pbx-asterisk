#!/bin/bash
set -euo pipefail

SCRIPT_VERSION="${SCRIPT_VERSION:-3.0}"
case "${1:-}" in
    --version|-V) printf "%s v%s\n" "$(basename "$0")" "${SCRIPT_VERSION}"; exit 0 ;;
esac
if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
    RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
else
    RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"
    YELLOW="$(printf '\033[1;33m')"; BLUE="$(printf '\033[0;34m')"
    CYAN="$(printf '\033[0;36m')"; BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
fi
ok()   { printf "${GREEN}%s${NC}\n"   "$*"; }
info() { printf "${BLUE}%s${NC}\n"    "$*"; }
warn() { printf "${YELLOW}%s${NC}\n"  "$*"; }
err()  { printf "${RED}%s${NC}\n"     "$*" >&2; }
hdr()  { printf "\n${BOLD}%s${NC}\n" "$*"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

usage() {
    printf "Usage: pbx-asterisk [options]\n\nAsterisk management.\n\nOptions:\n"
    printf "  (no args)        Show version and uptime\n"
    printf "  --cli            Open Asterisk CLI\n"
    printf "  --reload         Core reload\n"
    printf "  --restart        Safe restart sequence\n"
    printf "  --status         Channels and memory stats\n"
    printf "  --peers          Show PJSIP endpoints and registrations\n"
    printf "  --calls          Show active calls (concise)\n"
    printf "  --log LEVEL      Set verbose log level\n"
    printf "  --upgrade VER    Upgrade Asterisk to VERSION\n"
    printf "  --help (alias: -h)        Show help
  --version (alias: -V)  Show version\n"; exit 0
}

need_ast() { command -v asterisk >/dev/null 2>&1 || { err "Asterisk not found"; exit 1; }; }

case "${1:-}" in
    --help|-h) usage ;;
    --cli)
        need_ast
        exec asterisk -rvvv ;;
    --reload)
        need_ast
        hdr "Reloading Asterisk"
        timeout 10 asterisk -rx "core reload" 2>/dev/null && ok "Reloaded" || err "Reload failed" ;;
    --restart)
        need_ast
        hdr "Restarting Asterisk"
        if command -v fwconsole >/dev/null 2>&1; then
            fwconsole restart 2>/dev/null && ok "FreePBX/Asterisk restarted"
        else
            timeout 15 asterisk -rx "core restart gracefully" 2>/dev/null && ok "Graceful restart initiated" || \
            timeout 5  asterisk -rx "core restart now" 2>/dev/null && ok "Forced restart"
        fi ;;
    --status)
        need_ast
        hdr "Active Channels"
        timeout 5 asterisk -rx "core show channels" 2>/dev/null || warn "Could not get channels"
        hdr "Memory Stats"
        timeout 5 asterisk -rx "core show memory stats" 2>/dev/null || warn "Could not get memory stats" ;;
    --peers)
        need_ast
        hdr "PJSIP Endpoints"
        timeout 5 asterisk -rx "pjsip show endpoints" 2>/dev/null || warn "Could not get endpoints"
        hdr "PJSIP Registrations"
        timeout 5 asterisk -rx "pjsip show registrations" 2>/dev/null || warn "Could not get registrations" ;;
    --calls)
        need_ast
        hdr "Active Calls (concise)"
        timeout 5 asterisk -rx "core show channels concise" 2>/dev/null || warn "No active calls or Asterisk unavailable" ;;
    --log)
        LEVEL="${2:-3}"
        need_ast
        timeout 5 asterisk -rx "core set verbose ${LEVEL}" 2>/dev/null && ok "Verbose level set to ${LEVEL}" ;;
    --upgrade)
        VER="${2:-}"; [ -z "$VER" ] && { err "--upgrade requires a VERSION"; exit 1; }
        printf "Upgrade Asterisk to %s? This will recompile and reinstall. [y/N] " "$VER"; read -r C
        [ "$C" != "y" ] && [ "$C" != "Y" ] && { info "Aborted."; exit 0; }
        hdr "Downloading Asterisk ${VER}"
        DLDIR="/usr/src/asterisk-${VER}"
        mkdir -p "$DLDIR"
        URL="https://downloads.asterisk.org/pub/telephony/asterisk/asterisk-${VER}-current.tar.gz"
        if command -v curl >/dev/null 2>&1; then
            curl -fsSL "$URL" | tar -xz -C /usr/src/ 2>/dev/null || { err "Download failed"; exit 1; }
        elif command -v wget >/dev/null 2>&1; then
            wget -qO- "$URL" | tar -xz -C /usr/src/ 2>/dev/null || { err "Download failed"; exit 1; }
        fi
        cd /usr/src/asterisk-${VER}* 2>/dev/null || { err "Could not find extracted directory"; exit 1; }
        ./configure --with-jansson-bundled >/dev/null 2>&1 && make -j"$(nproc)" >/dev/null 2>&1 && \
            make install >/dev/null 2>&1 && ok "Asterisk ${VER} installed" || err "Build failed"
        fwconsole restart 2>/dev/null || asterisk -rx "core restart now" 2>/dev/null || true ;;
    *)
        need_ast
        hdr "Asterisk Status"
        timeout 5 asterisk -rx "core show version" 2>/dev/null || asterisk -V 2>/dev/null
        echo ""
        timeout 5 asterisk -rx "core show uptime" 2>/dev/null || warn "Could not get uptime" ;;
esac
