#!/bin/bash
set -euo pipefail
setup_output() {
    if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
        RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
        USE_EMOJI=0
        SYM_OK="+"; SYM_FAIL="-"
    else
        RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"; YELLOW="$(printf '\033[1;33m')"
        BLUE="$(printf '\033[0;34m')"; CYAN="$(printf '\033[0;36m')"
        BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
        USE_EMOJI=1
        SYM_OK="✓"; SYM_FAIL="✗"
    fi
}
setup_output
e() { [ "$USE_EMOJI" = "1" ] && printf "%s " "$1" || true; }
_strip_e() { [ "${USE_EMOJI:-0}" = "1" ] && printf '%s' "$*" || printf '%s' "$*" | tr -dc '-'; }
ok()   { local m; m=$(_strip_e "$*"); printf "%s${GREEN}%s${NC}
" "$(e ✅)" "${m}"; }
info() { local m; m=$(_strip_e "$*"); printf "%s${BLUE}%s${NC}
"  "$(e ℹ️ )" "${m}"; }
warn() { local m; m=$(_strip_e "$*"); printf "%s${YELLOW}%s${NC}
" "$(e ⚠️ )" "${m}"; }
err()  { local m; m=$(_strip_e "$*"); printf "%s${RED}%s${NC}
" "$(e ❌)" "${m}" >&2; }
hdr()  { local m; m=$(_strip_e "$*"); printf "
${BOLD}%s%s${NC}
" "$(e 🔧)" "${m}"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

GITHUB_REPO="${GITHUB_REPO:-scriptmgr/pbx}"
SCRIPTS_REF="${SCRIPTS_REF:-main}"
INSTALL_DIR="/usr/local/bin"
API_URL="https://api.github.com/repos/${GITHUB_REPO}/contents/scripts?ref=${SCRIPTS_REF}"

usage() {
    printf "Usage: pbx-update [--check] [--force]\n\nSelf-update management scripts from GitHub.\n\nOptions:\n"
    printf "  (no args)   Update changed scripts\n"
    printf "  --check     Show which scripts are outdated without updating\n"
    printf "  --force     Update all scripts regardless of changes\n"
    printf "  --help/-h   Show help\n"; exit 0
}

CHECK_ONLY=0; FORCE=0
for arg in "$@"; do case "$arg" in
    --help|-h) usage ;; --check) CHECK_ONLY=1 ;; --force) FORCE=1 ;;
esac; done

command -v curl >/dev/null 2>&1 || { err "curl is required for pbx-update"; exit 1; }

hdr "Fetching script list from GitHub (${GITHUB_REPO})"
FILE_LIST=$(curl -fsSL "$API_URL" 2>/dev/null) || { err "Could not fetch file list from GitHub"; exit 1; }

UPDATED=0; SKIPPED=0
printf '%s\n' "$FILE_LIST" | grep '"download_url"' | sed 's/.*"download_url": "//;s/".*//' | \
while IFS= read -r url; do
    [ -z "$url" ] && continue
    SCRIPT_NAME=$(basename "$url")
    INSTALLED="${INSTALL_DIR}/${SCRIPT_NAME}"
    NEW_CONTENT=$(curl -fsSL "$url" 2>/dev/null) || { warn "Could not download ${SCRIPT_NAME}"; continue; }
    if [ "$FORCE" -eq 1 ] || [ ! -f "$INSTALLED" ] || \
       [ "$(printf '%s' "$NEW_CONTENT" | md5sum)" != "$(md5sum "$INSTALLED" 2>/dev/null | cut -d' ' -f1)" ]; then
        if [ "$CHECK_ONLY" -eq 1 ]; then
            warn "  Outdated: ${SCRIPT_NAME}"
        else
            printf '%s\n' "$NEW_CONTENT" > "$INSTALLED"
            chmod 755 "$INSTALLED"
            ok "  Updated: ${SCRIPT_NAME}"
            UPDATED=$((UPDATED+1))
        fi
    else
        info "  Current: ${SCRIPT_NAME}"
        SKIPPED=$((SKIPPED+1))
    fi
done

if [ "$CHECK_ONLY" -eq 0 ]; then
    hdr "Upgrading FreePBX modules"
    command -v fwconsole >/dev/null 2>&1 && \
        fwconsole ma upgradeall 2>/dev/null && ok "FreePBX modules upgraded" || \
        warn "Could not upgrade FreePBX modules"
fi

ok "Update complete"
