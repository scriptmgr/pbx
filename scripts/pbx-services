#!/bin/bash
set -euo pipefail
setup_output() {
    if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
        RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
        USE_EMOJI=0
        SYM_OK="+"; SYM_FAIL="-"
    else
        RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"; YELLOW="$(printf '\033[1;33m')"
        BLUE="$(printf '\033[0;34m')"; CYAN="$(printf '\033[0;36m')"
        BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
        USE_EMOJI=1
        SYM_OK="✓"; SYM_FAIL="✗"
    fi
}
setup_output
e() { [ "$USE_EMOJI" = "1" ] && printf "%s " "$1" || true; }
_strip_e() { [ "${USE_EMOJI:-0}" = "1" ] && printf '%s' "$*" || printf '%s' "$*" | tr -dc '-'; }
ok()   { local m; m=$(_strip_e "$*"); printf "%s${GREEN}%s${NC}
" "$(e ✅)" "${m}"; }
info() { local m; m=$(_strip_e "$*"); printf "%s${BLUE}%s${NC}
"  "$(e ℹ️ )" "${m}"; }
warn() { local m; m=$(_strip_e "$*"); printf "%s${YELLOW}%s${NC}
" "$(e ⚠️ )" "${m}"; }
err()  { local m; m=$(_strip_e "$*"); printf "%s${RED}%s${NC}
" "$(e ❌)" "${m}" >&2; }
hdr()  { local m; m=$(_strip_e "$*"); printf "
${BOLD}%s%s${NC}
" "$(e 🔧)" "${m}"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

# Build service list using env-provided names where available, falling back to detection
_web="${APACHE_SERVICE:-}"
[ -z "$_web" ] && { command -v apache2 >/dev/null 2>&1 && _web="apache2" || _web="httpd"; }
_fpm="${PHP_FPM_SERVICE:-}"
[ -z "$_fpm" ] && _fpm="php-fpm"
SERVICES="asterisk freepbx mariadb ${_web} ${_fpm} fail2ban postfix hylafax iaxmodem webmin"

usage() {
    printf "Usage: pbx-services [--restart NAME] [--enable NAME] [--logs NAME]\n\nMonitor PBX services.\n\nOptions:\n"
    printf "  (no args)        List all service statuses\n"
    printf "  --restart NAME   Restart a specific service\n"
    printf "  --enable  NAME   Enable a service to start on boot\n"
    printf "  --logs    NAME   Show last 20 lines of service logs\n"
    printf "  --help/-h        Show help\n"; exit 0
}

svc_state() {
    local svc="$1"
    if command -v systemctl >/dev/null 2>&1; then
        systemctl is-active "$svc" 2>/dev/null
    else
        service "$svc" status >/dev/null 2>&1 && echo "active" || echo "inactive"
    fi
}

show_all() {
    hdr "PBX Service Status"
    for svc in $SERVICES; do
        state=$(svc_state "$svc")
        case "$state" in
            active)
                ok "  $(printf '%-20s' "$svc") $state" ;;
            failed)
                err "  $(printf '%-20s' "$svc") $state" ;;
            inactive)
                if systemctl list-unit-files --type=service 2>/dev/null | grep -q "^${svc}" || \
                   [ -f "/etc/init.d/${svc}" ]; then
                    warn "  $(printf '%-20s' "$svc") $state"
                fi ;;
        esac
    done
}

case "${1:-}" in
    --help|-h) usage ;;
    --restart)
        SVC="${2:-}"; [ -z "$SVC" ] && { err "--restart requires a service name"; exit 1; }
        hdr "Restarting ${SVC}"
        if command -v systemctl >/dev/null 2>&1; then
            systemctl restart "$SVC" && ok "${SVC} restarted" || err "${SVC} restart failed"
        else
            service "$SVC" restart && ok "${SVC} restarted" || err "${SVC} restart failed"
        fi ;;
    --enable)
        SVC="${2:-}"; [ -z "$SVC" ] && { err "--enable requires a service name"; exit 1; }
        if command -v systemctl >/dev/null 2>&1; then
            systemctl enable "$SVC" && ok "${SVC} enabled" || err "Failed to enable ${SVC}"
        else
            chkconfig "$SVC" on 2>/dev/null && ok "${SVC} enabled" || warn "Could not enable ${SVC}"
        fi ;;
    --logs)
        SVC="${2:-}"; [ -z "$SVC" ] && { err "--logs requires a service name"; exit 1; }
        hdr "Logs for ${SVC}"
        if command -v journalctl >/dev/null 2>&1; then
            journalctl -u "$SVC" -n 20 --no-pager 2>/dev/null || true
        elif [ -f "/var/log/${SVC}.log" ]; then
            tail -20 "/var/log/${SVC}.log"
        elif [ -f "/var/log/${SVC}" ]; then
            tail -20 "/var/log/${SVC}"
        else
            warn "No log found for ${SVC}"
        fi ;;
    *) show_all ;;
esac
