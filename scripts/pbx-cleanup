#!/usr/bin/env bash
# shellcheck shell=bash
# - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version           :  202605191156-git
# @@Author           :  Jason Hempstead
# @@Contact          :  git-admin@casjaysdev.pro
# @@License          :  MIT or LICENSE.md
# @@ReadME           :  pbx-cleanup --help | README.md
# @@Copyright        :  Copyright: (c) 2026 Jason Hempstead, Casjays Developments
# @@Created          :  Tuesday, May 19, 2026 11:56 EDT
# @@File             :  pbx-cleanup
# @@Description      :  Clean up old backup files and logs.
# @@Changelog        :  Add compliant script header; fix convention violations
# @@TODO             :
# @@Other            :
# @@Resource         :
# @@Terminal App     :  yes
# @@sudo/root        :  yes
# @@Template         :  shell/bash
# - - - - - - - - - - - - - - - - - - - - - - - - -
# shellcheck disable=SC1001,SC1003,SC2001,SC2003,SC2016,SC2031,SC2090,SC2115,SC2120,SC2155,SC2199,SC2229,SC2317,SC2329
# - - - - - - - - - - - - - - - - - - - - - - - - -
VERSION="202605191156-git"
APPNAME="${0##*/}"
RUN_USER="${USER}"
SET_UID="${UID}"
SCRIPT_SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
set -euo pipefail

case "${1:-}" in
    --version|-V) printf "%s v%s\n" "$(basename "$0")" "${VERSION}"; exit 0 ;;
esac
if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
    RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
else
    RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"
    YELLOW="$(printf '\033[1;33m')"; BLUE="$(printf '\033[0;34m')"
    CYAN="$(printf '\033[0;36m')"; BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
fi
ok()   { printf "${GREEN}%s${NC}\n"   "$*"; }
info() { printf "${BLUE}%s${NC}\n"    "$*"; }
warn() { printf "${YELLOW}%s${NC}\n"  "$*"; }
err()  { printf "${RED}%s${NC}\n"     "$*" >&2; }
hdr()  { printf "\n${BOLD}%s${NC}\n" "$*"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

BACKUP_DIR="${BACKUP_DIR:-/mnt/backups/pbx}"
DRY_RUN=0; AGGRESSIVE=0

usage() {
    printf "Usage: pbx-cleanup [--dry-run] [--aggressive]\n\nClean up old backup files and logs.\n\nOptions:\n"
    printf "  --dry-run    Preview without deleting\n"
    printf "  --aggressive Remove files older than 7 days\n  --help (alias: -h)    Show help
  --version (alias: -V)  Show version\n"; exit 0
}
for arg in "$@"; do case "$arg" in
    --help|-h) usage ;; --dry-run) DRY_RUN=1 ;; --aggressive) AGGRESSIVE=1 ;;
esac; done

CONFIG_DAYS=30; DB_DAYS=14; LOG_DAYS=30
[ "$AGGRESSIVE" -eq 1 ] && { CONFIG_DAYS=7; DB_DAYS=7; LOG_DAYS=7; }
[ "$DRY_RUN"    -eq 1 ] && warn "DRY RUN MODE - no files will be deleted"

FREED=0
__cleanup_dir() {
    local dir="$1" days="$2" label="$3"
    hdr "Cleaning ${label} (older than ${days} days)"
    [ ! -d "$dir" ] && { warn "Directory not found: $dir"; return; }
    while IFS= read -r -d '' f; do
        SIZE=$(du -sb "$f" 2>/dev/null | cut -f1)
        if [ "$DRY_RUN" -eq 1 ]; then
            info "  Would remove: $f ($(du -sh "$f" 2>/dev/null | cut -f1))"
        else
            rm -f "$f" && ok "  Removed: $f" || warn "  Could not remove: $f"
            FREED=$((FREED + ${SIZE:-0}))
        fi
    done < <(find "$dir" -maxdepth 2 -type f -mtime "+${days}" -print0 2>/dev/null)
}

__cleanup_dir "${BACKUP_DIR}/config"   "$CONFIG_DAYS" "Config backups"
__cleanup_dir "${BACKUP_DIR}/database" "$DB_DAYS"     "Database backups"
__cleanup_dir "/var/log/asterisk"      "$LOG_DAYS"    "Asterisk logs"

if [ "$DRY_RUN" -eq 0 ] && command -v asterisk >/dev/null 2>&1; then
    hdr "Rotating Asterisk logs"
    timeout 5 asterisk -rx "logger rotate" 2>/dev/null && ok "Logs rotated" || true
fi

if [ "$DRY_RUN" -eq 0 ] && [ "$FREED" -gt 0 ]; then
    FREED_MB=$(awk "BEGIN{printf \"%.1f MB\", $FREED/1048576}")
    ok "Total space freed: ${FREED_MB}"
fi
ok "Cleanup complete"
# ex: ts=2 sw=2 et filetype=sh
