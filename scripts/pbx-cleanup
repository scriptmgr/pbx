#!/bin/bash
set -euo pipefail
setup_output() {
    if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
        RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
        USE_EMOJI=0
    else
        RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"; YELLOW="$(printf '\033[1;33m')"
        BLUE="$(printf '\033[0;34m')"; CYAN="$(printf '\033[0;36m')"
        BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
        USE_EMOJI=1
    fi
}
setup_output
e() { [ "$USE_EMOJI" = "1" ] && printf "%s " "$1" || true; }
ok()   { printf "%s${GREEN}%s${NC}\n" "$(e ✅)" "$*"; }
info() { printf "%s${BLUE}%s${NC}\n"  "$(e ℹ️ )" "$*"; }
warn() { printf "%s${YELLOW}%s${NC}\n" "$(e ⚠️ )" "$*"; }
err()  { printf "%s${RED}%s${NC}\n" "$(e ❌)" "$*" >&2; }
hdr()  { printf "\n${BOLD}%s%s${NC}\n" "$(e 🔧)" "$*"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

BACKUP_DIR="${BACKUP_DIR:-/mnt/backups/pbx}"
DRY_RUN=0; AGGRESSIVE=0

usage() {
    printf "Usage: pbx-cleanup [--dry-run] [--aggressive]\n\nClean up old backup files and logs.\n\nOptions:\n"
    printf "  --dry-run    Preview without deleting\n"
    printf "  --aggressive Remove files older than 7 days\n  --help/-h    Show help\n"; exit 0
}
for arg in "$@"; do case "$arg" in
    --help|-h) usage ;; --dry-run) DRY_RUN=1 ;; --aggressive) AGGRESSIVE=1 ;;
esac; done

CONFIG_DAYS=30; DB_DAYS=14; LOG_DAYS=30
[ "$AGGRESSIVE" -eq 1 ] && { CONFIG_DAYS=7; DB_DAYS=7; LOG_DAYS=7; }
[ "$DRY_RUN"    -eq 1 ] && warn "DRY RUN MODE - no files will be deleted"

FREED=0
cleanup_dir() {
    local dir="$1" days="$2" label="$3"
    hdr "Cleaning ${label} (older than ${days} days)"
    [ ! -d "$dir" ] && { warn "Directory not found: $dir"; return; }
    while IFS= read -r -d '' f; do
        SIZE=$(du -sb "$f" 2>/dev/null | cut -f1)
        if [ "$DRY_RUN" -eq 1 ]; then
            info "  Would remove: $f ($(du -sh "$f" 2>/dev/null | cut -f1))"
        else
            rm -f "$f" && ok "  Removed: $f" || warn "  Could not remove: $f"
            FREED=$((FREED + ${SIZE:-0}))
        fi
    done < <(find "$dir" -maxdepth 2 -type f -mtime "+${days}" -print0 2>/dev/null)
}

cleanup_dir "${BACKUP_DIR}/config"   "$CONFIG_DAYS" "Config backups"
cleanup_dir "${BACKUP_DIR}/database" "$DB_DAYS"     "Database backups"
cleanup_dir "/var/log/asterisk"      "$LOG_DAYS"    "Asterisk logs"

if [ "$DRY_RUN" -eq 0 ] && command -v asterisk >/dev/null 2>&1; then
    hdr "Rotating Asterisk logs"
    timeout 5 asterisk -rx "logger rotate" 2>/dev/null && ok "Logs rotated" || true
fi

if [ "$DRY_RUN" -eq 0 ] && [ "$FREED" -gt 0 ]; then
    FREED_MB=$(awk "BEGIN{printf \"%.1f MB\", $FREED/1048576}")
    ok "Total space freed: ${FREED_MB}"
fi
ok "Cleanup complete"
