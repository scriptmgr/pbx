#!/bin/bash
# PBX Backup Encryption Helper
set -euo pipefail

SCRIPT_VERSION="${SCRIPT_VERSION:-3.0}"
case "${1:-}" in
    --version|-V) printf "%s v%s\n" "$(basename "$0")" "${SCRIPT_VERSION}"; exit 0 ;;
esac

if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
    RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
else
    RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"
    YELLOW="$(printf '\033[1;33m')"; BLUE="$(printf '\033[0;34m')"
    CYAN="$(printf '\033[0;36m')"; BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
fi
ok()   { printf "${GREEN}%s${NC}\n"   "$*"; }
info() { printf "${BLUE}%s${NC}\n"    "$*"; }
warn() { printf "${YELLOW}%s${NC}\n"  "$*"; }
err()  { printf "${RED}%s${NC}\n"     "$*" >&2; }
hdr()  { printf "\n${BOLD}%s${NC}\n" "$*"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

PBX_ETC_DIR="/etc/pbx"
PBX_VAR_DIR="/var/lib/pbx"
GPG_BATCH_DIR="${PBX_VAR_DIR}/tmp"
PUBLIC_KEY_FILE="${PBX_ETC_DIR}/pbx-backup-key.pub"

usage() {
    printf "Usage: pbx-backup-encrypt <command> [args]\n\n"
    printf "Manage GPG encryption for PBX backups.\n\n"
    printf "Commands:\n"
    printf "  init              Generate a 4096-bit RSA GPG key for backup encryption\n"
    printf "  encrypt FILE      Encrypt a backup archive with the stored GPG key\n"
    printf "  status            Show current encryption configuration\n"
    printf "\nOptions:\n"
    printf "  --help (alias: -h)         Show help
  --version (alias: -V)  Show version\n"
    printf "\nExamples:\n"
    printf "  pbx-backup-encrypt init\n"
    printf "  pbx-backup-encrypt encrypt /mnt/backups/pbx/config/pbx-config-20250101.tar.gz\n"
    printf "  BACKUP_ENCRYPT=yes in /etc/pbx/.env to auto-encrypt on backup\n"
    exit 0
}

cmd_init() {
    command -v gpg >/dev/null 2>&1 || { err "gpg not found — install gnupg"; exit 1; }
    hdr "Generating GPG key for backup encryption"
    KEYNAME="PBX Backup $(hostname -f 2>/dev/null || hostname)"
    KEYEMAIL="backup@$(hostname -f 2>/dev/null || hostname)"
    mkdir -p "${PBX_ETC_DIR}" "${GPG_BATCH_DIR}"
    chmod 700 "${GPG_BATCH_DIR}" 2>/dev/null || true
    BATCH_FILE=$(mktemp "${GPG_BATCH_DIR}/pbx-gpg-batch.XXXXXX")
    chmod 600 "${BATCH_FILE}" 2>/dev/null || true
    cat > "${BATCH_FILE}" << GPGBATCH
%no-protection
Key-Type: RSA
Key-Length: 4096
Subkey-Type: RSA
Subkey-Length: 4096
Name-Real: ${KEYNAME}
Name-Email: ${KEYEMAIL}
Expire-Date: 0
%commit
GPGBATCH
    if gpg --batch --gen-key "${BATCH_FILE}" 2>/dev/null; then
        ok "GPG key generated"
    else
        rm -f "${BATCH_FILE}"
        err "GPG key generation failed"
        exit 1
    fi
    rm -f "${BATCH_FILE}"
    KEY_ID=$(gpg --list-keys --with-colons 2>/dev/null \
        | grep "^pub" | tail -1 | cut -d: -f5)
    if [ -z "$KEY_ID" ]; then
        err "Could not retrieve generated key ID"
        exit 1
    fi
    gpg --armor --export "${KEY_ID}" > "${PUBLIC_KEY_FILE}" 2>/dev/null
    chmod 600 "${PUBLIC_KEY_FILE}" 2>/dev/null || true
    ok "Public key exported: ${PUBLIC_KEY_FILE}"
    # Store key ID in /etc/pbx/.env
    mkdir -p "${PBX_ETC_DIR}"
    if [ -f /etc/pbx/.env ]; then
        grep -v "^BACKUP_GPG_KEY=" /etc/pbx/.env > /etc/pbx/.env.new 2>/dev/null \
            && mv /etc/pbx/.env.new /etc/pbx/.env || true
    fi
    printf "BACKUP_GPG_KEY=%s\n" "${KEY_ID}" >> /etc/pbx/.env
    grep -q "^BACKUP_ENCRYPT=" /etc/pbx/.env 2>/dev/null || \
        printf "BACKUP_ENCRYPT=no\n" >> /etc/pbx/.env
    ok "Key ID ${KEY_ID} saved to /etc/pbx/.env"
    info "Set BACKUP_ENCRYPT=yes in /etc/pbx/.env to enable auto-encryption"
}

cmd_encrypt() {
    ARCHIVE="${1:-}"
    [ -z "${ARCHIVE}" ] && { err "Usage: pbx-backup-encrypt encrypt <file>"; exit 1; }
    [ -f "${ARCHIVE}" ]  || { err "File not found: ${ARCHIVE}"; exit 1; }
    command -v gpg >/dev/null 2>&1 || { err "gpg not found — install gnupg"; exit 1; }
    [ -z "${BACKUP_GPG_KEY:-}" ] && {
        err "BACKUP_GPG_KEY not set — run: pbx-backup-encrypt init"
        exit 1
    }
    hdr "Encrypting ${ARCHIVE}"
    if gpg --batch --yes --encrypt --recipient "${BACKUP_GPG_KEY}" \
            --output "${ARCHIVE}.gpg" "${ARCHIVE}"; then
        rm -f "${ARCHIVE}"
        ok "Encrypted: ${ARCHIVE}.gpg"
    else
        err "Encryption failed"
        exit 1
    fi
}

cmd_status() {
    hdr "Backup Encryption Status"
    printf "  BACKUP_ENCRYPT  : %s\n" "${BACKUP_ENCRYPT:-no}"
    printf "  BACKUP_GPG_KEY  : %s\n" "${BACKUP_GPG_KEY:-(not set)}"
    if [ -n "${BACKUP_GPG_KEY:-}" ] && command -v gpg >/dev/null 2>&1; then
        if gpg --list-keys "${BACKUP_GPG_KEY}" >/dev/null 2>&1; then
            ok "  GPG key ${BACKUP_GPG_KEY} found in keyring"
        else
            err "  GPG key ${BACKUP_GPG_KEY} NOT found in keyring"
        fi
    fi
}

case "${1:-}" in
    --help|-h) usage ;;
    init)      cmd_init ;;
    encrypt)   shift; cmd_encrypt "$@" ;;
    status)    cmd_status ;;
    *)
        err "Unknown command: ${1:-}"
        printf "Run 'pbx-backup-encrypt --help' for usage.\n" >&2
        exit 1
        ;;
esac
