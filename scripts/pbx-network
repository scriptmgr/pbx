#!/bin/bash
set -euo pipefail
if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
    RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
else
    RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"
    YELLOW="$(printf '\033[1;33m')"; BLUE="$(printf '\033[0;34m')"
    CYAN="$(printf '\033[0;36m')"; BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
fi
ok()   { printf "${GREEN}%s${NC}\n"   "$*"; }
info() { printf "${BLUE}%s${NC}\n"    "$*"; }
warn() { printf "${YELLOW}%s${NC}\n"  "$*"; }
err()  { printf "${RED}%s${NC}\n"     "$*" >&2; }
hdr()  { printf "\n${BOLD}%s${NC}\n" "$*"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

usage() { printf "Usage: pbx-network\nNetwork diagnostics for PBX.\n\nOptions:\n  --help/-h  Show help\n"; exit 0; }
[ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ] && usage

hdr "Network Interfaces"
if command -v ip >/dev/null 2>&1; then
    ip addr show 2>/dev/null | grep -E '^[0-9]|inet '
elif command -v ifconfig >/dev/null 2>&1; then
    ifconfig 2>/dev/null
else
    warn "No network interface tool found"
fi

hdr "IP Addresses"
PRIV_IP=$(hostname -I 2>/dev/null | awk '{print $1}')
printf "  Private IP: %s\n" "${PRIV_IP:-unknown}"
PUB_IP="${PUBLIC_IP:-}"
if [ -z "$PUB_IP" ]; then
    if command -v curl >/dev/null 2>&1; then
        PUB_IP=$(timeout 5 curl -s https://api4.my-ip.io/ip 2>/dev/null || echo "unavailable")
    elif command -v wget >/dev/null 2>&1; then
        PUB_IP=$(timeout 5 wget -qO- https://api4.my-ip.io/ip 2>/dev/null || echo "unavailable")
    fi
fi
printf "  Public  IP: %s\n" "${PUB_IP:-unknown}"

if [ -n "$PUB_IP" ] && [ -n "$PRIV_IP" ] && [ "$PUB_IP" != "$PRIV_IP" ] && \
   [ "$PUB_IP" != "unavailable" ]; then
    warn "NAT detected: Private ${PRIV_IP} != Public ${PUB_IP}"
    info "Recommended Asterisk NAT settings for pjsip.conf:"
    printf "  [transport-udp]\n  type=transport\n  protocol=udp\n  bind=0.0.0.0\n"
    printf "  external_media_address=%s\n  external_signaling_address=%s\n" "$PUB_IP" "$PUB_IP"
    printf "  local_net=%s/255.255.255.0\n" "$(echo "$PRIV_IP" | cut -d. -f1-3).0"
fi

hdr "DNS Check"
for host in google.com voip.ms sipgate.com; do
    if command -v dig >/dev/null 2>&1; then
        IP_R=$(timeout 3 dig +short "$host" 2>/dev/null | head -1)
        [ -n "$IP_R" ] && ok "  DNS: $host -> $IP_R" || err "  DNS: $host FAILED"
    elif command -v nslookup >/dev/null 2>&1; then
        timeout 3 nslookup "$host" >/dev/null 2>&1 && ok "  DNS: $host OK" || err "  DNS: $host FAILED"
    fi
done

hdr "SIP Port Check"
info "Checking SIP ports (506x):"
if command -v ss >/dev/null 2>&1; then
    ss -tulnp 2>/dev/null | grep -E ':506[0-9]' || warn "No SIP ports detected"
elif command -v netstat >/dev/null 2>&1; then
    netstat -tulnp 2>/dev/null | grep -E ':506[0-9]' || warn "No SIP ports detected"
fi

hdr "Latency to VoIP Providers"
for host in voip.ms sipgate.com; do
    if command -v ping >/dev/null 2>&1; then
        LAT=$(timeout 5 ping -c 3 -q "$host" 2>/dev/null | grep -E "rtt|round-trip" | awk -F'/' '{print $5}')
        [ -n "$LAT" ] && ok "  ${host}: ${LAT}ms avg" || warn "  ${host}: ping failed or no response"
    fi
done

hdr "Routing Table"
if command -v ip >/dev/null 2>&1; then ip route 2>/dev/null
elif command -v route >/dev/null 2>&1; then route -n 2>/dev/null; fi
