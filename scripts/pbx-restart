#!/bin/bash
set -euo pipefail
setup_output() {
    if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
        RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
        USE_EMOJI=0
    else
        RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"; YELLOW="$(printf '\033[1;33m')"
        BLUE="$(printf '\033[0;34m')"; CYAN="$(printf '\033[0;36m')"
        BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
        USE_EMOJI=1
    fi
}
setup_output
e() { [ "$USE_EMOJI" = "1" ] && printf "%s " "$1" || true; }
ok()   { printf "%s${GREEN}%s${NC}\n" "$(e ✅)" "$*"; }
info() { printf "%s${BLUE}%s${NC}\n"  "$(e ℹ️ )" "$*"; }
warn() { printf "%s${YELLOW}%s${NC}\n" "$(e ⚠️ )" "$*"; }
err()  { printf "%s${RED}%s${NC}\n" "$(e ❌)" "$*" >&2; }
hdr()  { printf "\n${BOLD}%s%s${NC}\n" "$(e 🔧)" "$*"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

usage() {
    printf "Usage: pbx-restart [--force]\n\nSafely restart PBX services.\n\nOptions:\n"
    printf "  --force    Skip confirmation\n  --help/-h  Show help\n"; exit 0
}
FORCE=0
case "${1:-}" in --help|-h) usage ;; --force) FORCE=1 ;; esac

if [ "$FORCE" -eq 0 ]; then
    printf "Restart PBX? This will drop active calls. [y/N] "
    read -r CONFIRM
    [ "$CONFIRM" != "y" ] && [ "$CONFIRM" != "Y" ] && { info "Aborted."; exit 0; }
fi

hdr "Stopping Asterisk gracefully"
if command -v asterisk >/dev/null 2>&1; then
    info "Sending graceful stop (30s timeout)..."
    timeout 30 asterisk -rx "core stop gracefully" 2>/dev/null && sleep 5 || {
        warn "Graceful stop timed out, forcing..."
        timeout 10 asterisk -rx "core stop now" 2>/dev/null || true
    }
fi

hdr "Stopping FreePBX"
command -v fwconsole >/dev/null 2>&1 && fwconsole stop 2>/dev/null || true
info "Waiting 3 seconds..."; sleep 3

hdr "Starting FreePBX"
if command -v fwconsole >/dev/null 2>&1; then
    fwconsole start 2>/dev/null && ok "FreePBX started" || { err "FreePBX start failed"; exit 1; }
else
    err "fwconsole not found"; exit 1
fi
info "Waiting 5 seconds..."; sleep 5

hdr "Reloading FreePBX config"
fwconsole reload 2>/dev/null && ok "FreePBX reloaded" || warn "Reload had warnings"

hdr "Verifying Asterisk"
sleep 2
if command -v asterisk >/dev/null 2>&1; then
    if timeout 5 asterisk -rx "core show version" >/dev/null 2>&1; then
        ok "Asterisk is running"
        asterisk -rx "core show channels" 2>/dev/null
    else
        err "Asterisk does not appear to be running!"; exit 1
    fi
fi
ok "PBX restart complete"
