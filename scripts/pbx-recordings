#!/bin/bash
setup_output() {
    if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
        RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
        USE_EMOJI=0
    else
        RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"; YELLOW="$(printf '\033[1;33m')"
        BLUE="$(printf '\033[0;34m')"; CYAN="$(printf '\033[0;36m')"
        BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
        USE_EMOJI=1
    fi
}
setup_output
e() { [ "$USE_EMOJI" = "1" ] && printf "%s " "$1" || true; }
ok()   { printf "%s${GREEN}%s${NC}\n" "$(e ✅)" "$*"; }
info() { printf "%s${BLUE}%s${NC}\n"  "$(e ℹ️ )" "$*"; }
warn() { printf "%s${YELLOW}%s${NC}\n" "$(e ⚠️ )" "$*"; }
err()  { printf "%s${RED}%s${NC}\n" "$(e ❌)" "$*" >&2; }
hdr()  { printf "\n${BOLD}%s%s${NC}\n" "$(e 🔧)" "$*"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

REC_DIR="/var/spool/asterisk/monitor"
ARCH_DIR="/mnt/backups/pbx/recordings"

usage() {
    printf "Usage: pbx-recordings [options]\n\nCall recording management.\n\nOptions:\n"
    printf "  (no args) / --list [DATE]  List recordings (optionally filter by YYYYMMDD)\n"
    printf "  --play FILE                Play a recording\n"
    printf "  --delete FILE              Delete a recording\n"
    printf "  --archive                  Archive recordings older than 30 days\n"
    printf "  --search CALLERID          Find recordings by caller ID in filename\n"
    printf "  --help/-h                  Show help\n"; exit 0
}

case "${1:-}" in
    --help|-h) usage ;;
    --list|"")
        DATE="${2:-}"
        hdr "Call Recordings (${REC_DIR})"
        if [ ! -d "$REC_DIR" ]; then
            warn "Recording directory not found: $REC_DIR"; exit 0
        fi
        if [ -n "$DATE" ]; then
            find "$REC_DIR" -maxdepth 2 -type f -name "*${DATE}*" 2>/dev/null | sort | tail -20
        else
            find "$REC_DIR" -maxdepth 2 -type f 2>/dev/null | sort -t- -k1 | tail -20
        fi | while IFS= read -r f; do
            printf "  %s  (%s)\n" "$(basename "$f")" "$(du -sh "$f" 2>/dev/null | cut -f1)"
        done ;;
    --play)
        FILE="${2:-}"; [ -z "$FILE" ] && { err "--play requires a FILE"; exit 1; }
        [ ! -f "$FILE" ] && FILE="${REC_DIR}/${FILE}"
        [ ! -f "$FILE" ] && { err "File not found: $FILE"; exit 1; }
        if command -v aplay >/dev/null 2>&1; then
            aplay "$FILE" 2>/dev/null && ok "Playback complete" || warn "aplay failed"
        elif command -v sox >/dev/null 2>&1; then
            sox "$FILE" -t alsa default 2>/dev/null && ok "Playback complete" || warn "sox playback failed"
        else
            info "No audio player found. File: $FILE"
        fi ;;
    --delete)
        FILE="${2:-}"; [ -z "$FILE" ] && { err "--delete requires a FILE"; exit 1; }
        [ ! -f "$FILE" ] && FILE="${REC_DIR}/${FILE}"
        [ ! -f "$FILE" ] && { err "File not found: $FILE"; exit 1; }
        printf "Delete %s? [y/N] " "$FILE"; read -r C
        [ "$C" != "y" ] && [ "$C" != "Y" ] && { info "Aborted."; exit 0; }
        rm -f "$FILE" && ok "Deleted: $(basename "$FILE")" || err "Could not delete file" ;;
    --archive)
        hdr "Archiving recordings older than 30 days"
        mkdir -p "$ARCH_DIR"
        ARCH_FILE="${ARCH_DIR}/recordings-$(date +%Y%m%d).tar.gz"
        find "$REC_DIR" -maxdepth 2 -type f -mtime +30 -print0 2>/dev/null | \
            tar -czf "$ARCH_FILE" --null -T - 2>/dev/null \
            && ok "Archived to: $ARCH_FILE ($(du -sh "$ARCH_FILE" 2>/dev/null | cut -f1))" \
            || warn "Nothing to archive or archive failed"
        find "$REC_DIR" -maxdepth 2 -type f -mtime +30 -delete 2>/dev/null
        ok "Old recordings removed from ${REC_DIR}" ;;
    --search)
        CID="${2:-}"; [ -z "$CID" ] && { err "--search requires a CALLERID"; exit 1; }
        hdr "Searching recordings for CallerID: ${CID}"
        find "$REC_DIR" -maxdepth 2 -type f -name "*${CID}*" 2>/dev/null | while IFS= read -r f; do
            printf "  %s\n" "$f"
        done || info "No recordings found for ${CID}" ;;
esac
