#!/bin/bash
set -euo pipefail
setup_output() {
    if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
        RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
        USE_EMOJI=0
    else
        RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"; YELLOW="$(printf '\033[1;33m')"
        BLUE="$(printf '\033[0;34m')"; CYAN="$(printf '\033[0;36m')"
        BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
        USE_EMOJI=1
    fi
}
setup_output
e() { [ "$USE_EMOJI" = "1" ] && printf "%s " "$1" || true; }
ok()   { printf "%s${GREEN}%s${NC}\n" "$(e ✅)" "$*"; }
info() { printf "%s${BLUE}%s${NC}\n"  "$(e ℹ️ )" "$*"; }
warn() { printf "%s${YELLOW}%s${NC}\n" "$(e ⚠️ )" "$*"; }
err()  { printf "%s${RED}%s${NC}\n" "$(e ❌)" "$*" >&2; }
hdr()  { printf "\n${BOLD}%s%s${NC}\n" "$(e 🔧)" "$*"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ -f /root/.pbx_passwords ] && . /root/.pbx_passwords 2>/dev/null || true
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

BACKUP_DIR="${BACKUP_DIR:-/mnt/backups/pbx}"
TIMESTAMP=$(date +%Y%m%d-%H%M%S)

usage() {
    printf "Usage: pbx-backup [OPTION]\n\nOptions:\n"
    printf "  full, --now    Full backup — config + database (default)\n"
    printf "  config         Config files only\n"
    printf "  db             Database only\n"
    printf "  status, list   List existing backups and total size\n"
    printf "  --restore FILE Restore config from backup archive\n"
    printf "  --help/-h      Show help\n"; exit 0
}

backup_config() {
    hdr "Backing up configuration"
    local out="${BACKUP_DIR}/config/pbx-config-${TIMESTAMP}.tar.gz"
    local dirs=""
    [ -d /etc/asterisk ]     && dirs="$dirs /etc/asterisk"
    [ -f /etc/freepbx.conf ] && dirs="$dirs /etc/freepbx.conf"
    [ -d /etc/pbx ]          && dirs="$dirs /etc/pbx"
    if [ -n "$dirs" ]; then
        # shellcheck disable=SC2086
        tar -czf "$out" $dirs 2>/dev/null \
            && ok "Config backup: $out ($(du -sh "$out" 2>/dev/null | cut -f1))" \
            || err "Config backup failed"
    else
        warn "No config directories found"
    fi
}

backup_db() {
    hdr "Backing up database"
    command -v mysqldump >/dev/null 2>&1 || { err "mysqldump not found"; return 1; }
    local out="${BACKUP_DIR}/database/pbx-db-${TIMESTAMP}.sql.gz"
    MYSQL_OPTS=""
    [ -n "${MYSQL_ROOT_PASSWORD:-}" ] && MYSQL_OPTS="-p${MYSQL_ROOT_PASSWORD}"
    # shellcheck disable=SC2086
    mysqldump $MYSQL_OPTS --databases asterisk asteriskcdrdb 2>/dev/null | gzip > "$out" \
        && ok "DB backup: $out ($(du -sh "$out" 2>/dev/null | cut -f1))" \
        || err "Database backup failed"
}

show_status() {
    hdr "Existing Backups in ${BACKUP_DIR}"
    if [ -d "$BACKUP_DIR" ]; then
        find "$BACKUP_DIR" -type f \( -name "*.tar.gz" -o -name "*.sql.gz" \) 2>/dev/null \
            | sort | while IFS= read -r f; do
                printf "  %s  (%s)\n" "$f" "$(du -sh "$f" 2>/dev/null | cut -f1)"
            done
        TOTAL=$(du -sh "$BACKUP_DIR" 2>/dev/null | cut -f1)
        info "Total backup size: ${TOTAL}"
    else
        warn "Backup directory not found: ${BACKUP_DIR}"
    fi
}

MODE="full"
case "${1:-}" in
    --help|-h)            usage ;;
    full|--full|--now)    MODE="full" ;;
    config|--config)      MODE="config" ;;
    db|--db)              MODE="db" ;;
    status|list|--list)   show_status; exit 0 ;;
    --restore)
        FILE="${2:-}"; [ -z "$FILE" ] && { err "--restore requires a FILE"; exit 1; }
        [ ! -f "$FILE" ] && { err "File not found: $FILE"; exit 1; }
        hdr "Restoring from ${FILE}"
        printf "WARNING: Overwrites current config. Continue? [y/N] "; read -r C
        [ "$C" != "y" ] && [ "$C" != "Y" ] && { info "Aborted."; exit 0; }
        tar -xzf "$FILE" -C / 2>/dev/null && ok "Restored" || err "Restore failed"
        exit $? ;;
esac

mkdir -p "${BACKUP_DIR}/config" "${BACKUP_DIR}/database"
case "$MODE" in
    config) backup_config ;;
    db)     backup_db ;;
    full)   backup_config; backup_db ;;
esac
ok "Backup complete. Location: ${BACKUP_DIR}"
