#!/bin/bash
# Sync PBX backups to remote storage via rclone
set -euo pipefail

if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
    RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
else
    RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"
    YELLOW="$(printf '\033[1;33m')"; BLUE="$(printf '\033[0;34m')"
    CYAN="$(printf '\033[0;36m')"; BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
fi
ok()   { printf "${GREEN}%s${NC}\n"   "$*"; }
info() { printf "${BLUE}%s${NC}\n"    "$*"; }
warn() { printf "${YELLOW}%s${NC}\n"  "$*"; }
err()  { printf "${RED}%s${NC}\n"     "$*" >&2; }
hdr()  { printf "\n${BOLD}%s${NC}\n" "$*"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

LOCAL_DIR="${BACKUP_LOCAL_DIR:-/mnt/backups/pbx}"

usage() {
    printf "Usage: pbx-backup-remote [--check] [--list]\n\n"
    printf "Sync PBX backups to remote storage via rclone.\n\n"
    printf "Configuration (in /etc/pbx/.env):\n"
    printf "  RCLONE_REMOTE=s3:my-bucket       S3 bucket\n"
    printf "  RCLONE_REMOTE=gdrive:pbx-backups Google Drive folder\n"
    printf "  BACKUP_LOCAL_DIR=/mnt/backups/pbx Local backup source (default)\n\n"
    printf "Options:\n"
    printf "  --check    Verify rclone is configured without syncing\n"
    printf "  --list     List files on remote\n"
    printf "  --help/-h  Show help\n\n"
    printf "Setup:\n"
    printf "  1. Set RCLONE_REMOTE in /etc/pbx/.env\n"
    printf "  2. Run: rclone config\n"
    printf "  3. Run: pbx-backup-remote --check\n"
    exit 0
}

check_deps() {
    command -v rclone >/dev/null 2>&1 || {
        err "rclone not found — install with: curl https://rclone.org/install.sh | bash"
        exit 1
    }
}

case "${1:-}" in
    --help|-h) usage ;;
    --check)
        check_deps
        hdr "rclone configuration check"
        REMOTE="${RCLONE_REMOTE:-}"
        [ -z "$REMOTE" ] && {
            err "RCLONE_REMOTE not set in /etc/pbx/.env"
            info "Example: RCLONE_REMOTE=s3:my-bucket"
            exit 1
        }
        info "Remote: ${REMOTE}"
        if rclone lsd "${REMOTE}" 2>/dev/null; then
            ok "rclone can reach remote: ${REMOTE}"
        else
            err "rclone cannot reach remote: ${REMOTE}"
            info "Run: rclone config"
            exit 1
        fi
        ;;
    --list)
        check_deps
        REMOTE="${RCLONE_REMOTE:-}"
        [ -z "$REMOTE" ] && { err "RCLONE_REMOTE not set in /etc/pbx/.env"; exit 1; }
        hdr "Remote files at ${REMOTE}/pbx-backups/"
        rclone ls "${REMOTE}/pbx-backups/" 2>/dev/null || warn "No remote files found"
        ;;
    "")
        check_deps
        REMOTE="${RCLONE_REMOTE:-}"
        [ -z "$REMOTE" ] && {
            err "RCLONE_REMOTE not configured in /etc/pbx/.env"
            info "Set RCLONE_REMOTE to your rclone destination, e.g.:"
            info "  RCLONE_REMOTE=s3:my-bucket"
            info "  RCLONE_REMOTE=gdrive:pbx-backups"
            info "Then run: rclone config"
            exit 1
        }
        [ -d "$LOCAL_DIR" ] || {
            err "Local backup directory not found: ${LOCAL_DIR}"
            info "Run pbx-backup first"
            exit 1
        }
        hdr "Syncing ${LOCAL_DIR} → ${REMOTE}/pbx-backups/"
        if rclone sync "${LOCAL_DIR}/" "${REMOTE}/pbx-backups/" --progress 2>&1; then
            ok "Remote backup sync complete"
        else
            err "rclone sync failed"
            exit 1
        fi
        ;;
    *)
        err "Unknown option: ${1}"
        printf "Run 'pbx-backup-remote --help' for usage.\n" >&2
        exit 1
        ;;
esac
