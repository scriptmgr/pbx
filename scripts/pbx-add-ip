#!/bin/bash
# pbx-add-ip - Add IP to firewall whitelist
set -euo pipefail

SCRIPT_VERSION="${SCRIPT_VERSION:-3.0}"
case "${1:-}" in
    --version|-V) printf "%s v%s\n" "$(basename "$0")" "${SCRIPT_VERSION}"; exit 0 ;;
esac

if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
    RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
else
    RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"
    YELLOW="$(printf '\033[1;33m')"; BLUE="$(printf '\033[0;34m')"
    CYAN="$(printf '\033[0;36m')"; BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
fi
ok()   { printf "${GREEN}%s${NC}\n"   "$*"; }
info() { printf "${BLUE}%s${NC}\n"    "$*"; }
warn() { printf "${YELLOW}%s${NC}\n"  "$*"; }
err()  { printf "${RED}%s${NC}\n"     "$*" >&2; }
hdr()  { printf "\n${BOLD}%s${NC}\n" "$*"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

WHITELIST_FILE="/etc/pbx/whitelist.txt"
SSH_PORT_FILE="/etc/pbx/ssh-port"

usage() {
    printf "Usage: pbx-add-ip IP [comment]\n\n"
    printf "Add an IP address to the PBX firewall whitelist.\n\n"
    printf "Arguments:\n"
    printf "  IP           IPv4 address or CIDR range (e.g., 1.2.3.4 or 10.0.0.0/8)\n"
    printf "  comment      Optional description (default: manual)\n\n"
    printf "Actions:\n"
    printf "  1. Add ACCEPT rule to iptables INPUT chain (position 1)\n"
    printf "  2. Save to /etc/pbx/whitelist.txt for persistence\n\n"
    printf "Options:\n"
    printf "  --list       Show current whitelist\n"
    printf "  --help (alias: -h)    Show help
  --version (alias: -V)  Show version\n\n"
    printf "Examples:\n"
    printf "  pbx-add-ip 1.2.3.4\n"
    printf "  pbx-add-ip 1.2.3.4 office\n"
    printf "  pbx-add-ip 10.0.0.0/8 'internal network'\n"
    exit 0
}

validate_ip() {
    local ip="$1" stripped oct1 oct2 oct3 oct4
    # Accept IPv4 or IPv4/CIDR
    case "$ip" in
        */*) stripped="${ip%%/*}" ;;
        *)   stripped="$ip" ;;
    esac
    # shellcheck disable=SC2162
    IFS='.' read -r oct1 oct2 oct3 oct4 <<EOF
$stripped
EOF
    for oct in "$oct1" "$oct2" "$oct3" "$oct4"; do
        case "$oct" in
            ''|*[!0-9]*) return 1 ;;
        esac
        [ "$oct" -ge 0 ] && [ "$oct" -le 255 ] || return 1
    done
    return 0
}

get_client_ip() {
    printf '%s' "${SSH_CLIENT%% *}" 2>/dev/null || true
}

add_iptables_rule() {
    local ip="$1" comment="$2"
    if iptables -C INPUT -s "$ip" -j ACCEPT 2>/dev/null; then
        info "iptables rule for $ip already exists"
        return 0
    fi
    if iptables -I INPUT 1 -s "$ip" -j ACCEPT \
            -m comment --comment "whitelist: ${comment}" 2>/dev/null; then
        ok "iptables: Added ACCEPT for $ip"
    else
        warn "Could not add iptables rule (may lack iptables or permissions)"
    fi
}

# Persist current iptables ruleset across reboots.
persist_iptables() {
    command -v iptables >/dev/null 2>&1 || return 0
    if command -v netfilter-persistent >/dev/null 2>&1; then
        netfilter-persistent save >/dev/null 2>&1 && return 0
    fi
    if [ -d /etc/iptables ] || command -v netfilter-persistent >/dev/null 2>&1; then
        mkdir -p /etc/iptables 2>/dev/null
        iptables-save > /etc/iptables/rules.v4 2>/dev/null && return 0
    fi
    if [ -d /etc/sysconfig ]; then
        if command -v service >/dev/null 2>&1 && service iptables save >/dev/null 2>&1; then
            return 0
        fi
        iptables-save > /etc/sysconfig/iptables 2>/dev/null && return 0
    fi
    return 1
}

save_to_whitelist() {
    local ip="$1" comment="$2"
    mkdir -p "$(dirname "$WHITELIST_FILE")"
    if [ -f "$WHITELIST_FILE" ] && grep -q "^${ip}[[:space:]]" "$WHITELIST_FILE" 2>/dev/null; then
        info "Already in whitelist: $ip"
        return 0
    fi
    printf "%s  %s\n" "$ip" "$comment" >> "$WHITELIST_FILE"
    ok "Saved to whitelist: $WHITELIST_FILE"
}

cmd_list() {
    hdr "Whitelist (${WHITELIST_FILE})"
    if [ -f "$WHITELIST_FILE" ]; then
        printf "  %-20s %s\n" "IP/Range" "Comment"
        printf "  %-20s %s\n" "--------------------" "--------------------"
        while IFS= read -r line; do
            case "$line" in '#'*|'') continue ;; esac
            ip=$(printf '%s' "$line" | awk '{print $1}')
            comment=$(printf '%s' "$line" | awk '{$1=""; sub(/^ /,""); print}')
            printf "  %-20s %s\n" "$ip" "$comment"
        done < "$WHITELIST_FILE"
    else
        info "(whitelist file not found)"
    fi
    printf "\n"
    hdr "Active iptables ACCEPT rules"
    iptables -L INPUT -n 2>/dev/null | grep ACCEPT | grep -v "state\|loopback" \
        | sed 's/^/  /' | head -20 || info "(iptables not available)"
    printf "\n"
}

case "${1:-}" in
    --help|-h) usage ;;
    --list)    cmd_list; exit 0 ;;
    "")        err "IP address required"; usage ;;
esac

ip="$1"
comment="${2:-manual}"

if ! validate_ip "$ip"; then
    err "Invalid IP address or CIDR: $ip"
    err "Use format: 1.2.3.4 or 1.2.3.0/24"
    exit 1
fi

client_ip=$(get_client_ip)
[ -n "$client_ip" ] && info "Your current SSH client IP: $client_ip"

ssh_port=$(cat "$SSH_PORT_FILE" 2>/dev/null || printf '22')
info "SSH port ($ssh_port) will remain open regardless"

add_iptables_rule "$ip" "$comment"
save_to_whitelist "$ip" "$comment"
persist_iptables && ok "iptables ruleset persisted across reboot" \
                  || warn "Could not persist iptables — run 'pbx-firewall --save' manually"
