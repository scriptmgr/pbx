#!/bin/bash
# pbx-add-ip - Add IP to firewall whitelist
set -euo pipefail

setup_output() {
    if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || \
       [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
        USE_COLOR=0; USE_EMOJI=0
        RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; DIM=""; NC=""
    else
        USE_COLOR=1; USE_EMOJI=1
        RED="\033[0;31m"; GREEN="\033[0;32m"; YELLOW="\033[1;33m"
        BLUE="\033[0;34m"; CYAN="\033[0;36m"; BOLD="\033[1m"; DIM="\033[2m"; NC="\033[0m"
    fi
}
setup_output
[ -f /etc/pbx/.env ] && . /etc/pbx/.env
_e() { [ "${USE_EMOJI:-1}" = "1" ] && echo "$1" || echo ""; }
info()    { printf "${BLUE}$(_e ℹ️)  %s${NC}\n" "$*"; }
success() { printf "${GREEN}$(_e ✅) %s${NC}\n" "$*"; }
warn()    { printf "${YELLOW}$(_e ⚠️)  %s${NC}\n" "$*" >&2; }
error()   { printf "${RED}$(_e ❌) %s${NC}\n" "$*" >&2; }

show_help() {
    cat <<'EOF'
Usage: pbx-add-ip IP [comment]

Add an IP address to the PBX firewall whitelist.

Arguments:
  IP           IPv4 address or CIDR range (e.g., 1.2.3.4 or 10.0.0.0/8)
  comment      Optional description (default: "manual")

Actions:
  1. Add ACCEPT rule to iptables INPUT chain (position 1)
  2. Save to /etc/pbx/whitelist.txt for persistence across reloads
  3. Never blocks SSH port

Examples:
  pbx-add-ip 1.2.3.4
  pbx-add-ip 1.2.3.4 "office"
  pbx-add-ip 10.0.0.0/8 "internal network"

Options:
  --list    Show current whitelist
  --help    Show this help
EOF
}

WHITELIST_FILE="/etc/pbx/whitelist.txt"
SSH_PORT_FILE="/etc/pbx/ssh-port"

validate_ip() {
    local ip="$1"
    # Accept IPv4 or IPv4/CIDR
    echo "$ip" | grep -qP '^(\d{1,3}\.){3}\d{1,3}(\/\d{1,2})?$' || return 1
    # Validate each octet
    local stripped="${ip%%/*}"
    local IFS='.'
    read -ra octets <<< "$stripped"
    for oct in "${octets[@]}"; do
        [ "$oct" -ge 0 ] && [ "$oct" -le 255 ] || return 1
    done
    return 0
}

get_client_ip() {
    echo "${SSH_CLIENT%% *}" 2>/dev/null \
        || who am i 2>/dev/null | grep -oP '\(\K[^)]+' | head -1 \
        || echo ""
}

add_iptables_rule() {
    local ip="$1" comment="$2"

    # Check if rule already exists
    if iptables -C INPUT -s "$ip" -j ACCEPT 2>/dev/null; then
        info "iptables rule for $ip already exists"
        return 0
    fi

    # Add at position 1 (highest priority)
    iptables -I INPUT 1 -s "$ip" -j ACCEPT \
        -m comment --comment "whitelist: ${comment}" 2>/dev/null && \
        success "iptables: Added ACCEPT for $ip" || \
        warn "Could not add iptables rule (may not have iptables or wrong permissions)"
}

save_to_whitelist() {
    local ip="$1" comment="$2"
    mkdir -p "$(dirname "$WHITELIST_FILE")"

    # Check if already in whitelist
    if [ -f "$WHITELIST_FILE" ] && grep -q "^${ip}[[:space:]]" "$WHITELIST_FILE" 2>/dev/null; then
        info "Already in whitelist: $ip"
        return 0
    fi

    echo "${ip}  ${comment}" >> "$WHITELIST_FILE"
    success "Saved to whitelist: $WHITELIST_FILE"
}

cmd_list() {
    printf "\n${BOLD}Whitelist (%s):${NC}\n\n" "$WHITELIST_FILE"
    if [ -f "$WHITELIST_FILE" ]; then
        printf "  %-20s %s\n" "IP/Range" "Comment"
        printf "  %-20s %s\n" "────────────────────" "────────────────────"
        while IFS= read -r line; do
            [[ "$line" =~ ^#.*$ || -z "$line" ]] && continue
            local ip comment
            ip=$(echo "$line" | awk '{print $1}')
            comment=$(echo "$line" | awk '{$1=""; print $0}' | sed 's/^ *//')
            printf "  %-20s %s\n" "$ip" "$comment"
        done < "$WHITELIST_FILE"
    else
        echo "  (whitelist file not found)"
    fi

    echo ""
    printf "${BOLD}Active iptables ACCEPT rules:${NC}\n\n"
    iptables -L INPUT -n 2>/dev/null | grep ACCEPT | grep -v "state\|loopback" \
        | sed 's/^/  /' | head -20 || echo "  (iptables not available)"
    echo ""
}

main() {
    case "${1:-}" in
        --help) show_help; exit 0 ;;
        --list) cmd_list; exit 0 ;;
        "")     show_help; exit 1 ;;
    esac

    local ip="$1"
    local comment="${2:-manual}"

    # Validate IP
    if ! validate_ip "$ip"; then
        error "Invalid IP address or CIDR: $ip"
        error "Use format: 1.2.3.4 or 1.2.3.0/24"
        exit 1
    fi

    # Warn about current client IP
    local client_ip
    client_ip=$(get_client_ip)
    if [ -n "$client_ip" ]; then
        info "Your current SSH client IP: $client_ip"
    fi

    # Ensure SSH is never blocked (safety notice)
    local ssh_port
    ssh_port=$(cat "$SSH_PORT_FILE" 2>/dev/null || echo "22")
    info "SSH port ($ssh_port) will remain open regardless"

    # Add the rule
    add_iptables_rule "$ip" "$comment"
    save_to_whitelist "$ip" "$comment"

    echo ""
    info "To persist rules across reboots, run: pbx-firewall reload"
}

main "$@"
