#!/bin/bash
setup_output() {
    if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
        RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
        USE_EMOJI=0
    else
        RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"; YELLOW="$(printf '\033[1;33m')"
        BLUE="$(printf '\033[0;34m')"; CYAN="$(printf '\033[0;36m')"
        BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
        USE_EMOJI=1
    fi
}
setup_output
e() { [ "$USE_EMOJI" = "1" ] && printf "%s " "$1" || true; }
ok()   { printf "%s${GREEN}%s${NC}\n" "$(e ✅)" "$*"; }
info() { printf "%s${BLUE}%s${NC}\n"  "$(e ℹ️ )" "$*"; }
warn() { printf "%s${YELLOW}%s${NC}\n" "$(e ⚠️ )" "$*"; }
err()  { printf "%s${RED}%s${NC}\n" "$(e ❌)" "$*" >&2; }
hdr()  { printf "\n${BOLD}%s%s${NC}\n" "$(e 🔧)" "$*"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

KEYS_DIR="/etc/asterisk/keys"
LE_DIR="/etc/letsencrypt/live"

usage() {
    printf "Usage: pbx-ssl [options]\n\nSSL certificate management.\n\nOptions:\n"
    printf "  (no args)           Show certificate status\n"
    printf "  --install DOMAIN    Install Let's Encrypt cert for DOMAIN\n"
    printf "  --renew             Renew certificates and deploy to Asterisk\n"
    printf "  --self-signed       Generate self-signed certificate\n"
    printf "  --status            Test SSL connection to localhost\n"
    printf "  --help/-h           Show help\n"; exit 0
}

days_left() {
    local cert="$1"
    command -v openssl >/dev/null 2>&1 || { echo 999; return; }
    [ -f "$cert" ] || { echo 999; return; }
    local exp_str exp_ts now_ts
    exp_str=$(openssl x509 -enddate -noout -in "$cert" 2>/dev/null | cut -d= -f2)
    exp_ts=$(date -d "$exp_str" +%s 2>/dev/null || date -j -f "%b %d %T %Y %Z" "$exp_str" +%s 2>/dev/null || echo 0)
    now_ts=$(date +%s)
    echo $(( (exp_ts - now_ts) / 86400 ))
}

show_cert() {
    local cert="$1" label="$2"
    local days; days=$(days_left "$cert")
    local exp; exp=$(openssl x509 -enddate -noout -in "$cert" 2>/dev/null | cut -d= -f2 || echo "unknown")
    if   [ "$days" -lt 7  ]; then err  "  ${label}: expires in ${days} days ($exp) - CRITICAL"
    elif [ "$days" -lt 30 ]; then warn "  ${label}: expires in ${days} days ($exp) - renew soon"
    else                           ok   "  ${label}: expires in ${days} days ($exp)"
    fi
}

case "${1:-}" in
    --help|-h) usage ;;
    --install)
        DOMAIN="${2:-}"; [ -z "$DOMAIN" ] && { err "--install requires a DOMAIN"; exit 1; }
        command -v certbot >/dev/null 2>&1 || { err "certbot not found"; exit 1; }
        hdr "Installing Let's Encrypt cert for ${DOMAIN}"
        certbot --apache -d "$DOMAIN" && ok "Certificate installed" || err "certbot failed" ;;
    --renew)
        hdr "Renewing Let's Encrypt certificates"
        command -v certbot >/dev/null 2>&1 || { err "certbot not found"; exit 1; }
        certbot renew --quiet 2>/dev/null && ok "Certificates renewed" || warn "Some renewals may have failed"
        mkdir -p "$KEYS_DIR"
        for domain_dir in "${LE_DIR}"/*/; do
            domain=$(basename "$domain_dir")
            [ -f "${domain_dir}fullchain.pem" ] && cp "${domain_dir}fullchain.pem" "${KEYS_DIR}/asterisk.crt"
            [ -f "${domain_dir}privkey.pem"   ] && cp "${domain_dir}privkey.pem"   "${KEYS_DIR}/asterisk.key"
            ok "Deployed cert for ${domain}"
        done
        command -v asterisk >/dev/null 2>&1 && timeout 5 asterisk -rx "core reload" >/dev/null 2>&1 || true ;;
    --self-signed)
        hdr "Generating self-signed certificate"
        command -v openssl >/dev/null 2>&1 || { err "openssl not found"; exit 1; }
        mkdir -p "$KEYS_DIR"
        openssl req -x509 -newkey rsa:4096 \
            -keyout "${KEYS_DIR}/asterisk.key" \
            -out    "${KEYS_DIR}/asterisk.crt" \
            -days 365 -nodes \
            -subj "/C=US/ST=State/L=City/O=PBX/CN=$(hostname)" 2>/dev/null \
            && ok "Self-signed cert generated in ${KEYS_DIR}" || err "openssl failed"
        chmod 600 "${KEYS_DIR}/asterisk.key" ;;
    --status)
        hdr "SSL Connection Test"
        if command -v openssl >/dev/null 2>&1; then
            echo | timeout 5 openssl s_client -connect localhost:443 2>&1 | grep -E "subject|issuer|verify" \
                || warn "Could not connect to HTTPS on localhost"
        elif command -v curl >/dev/null 2>&1; then
            curl -vI https://localhost/ 2>&1 | grep -i ssl || warn "SSL test inconclusive"
        fi ;;
    *)
        hdr "Certificate Status"
        info "Let's Encrypt (${LE_DIR}):"
        if [ -d "$LE_DIR" ]; then
            for cert in "${LE_DIR}"/*/cert.pem; do
                [ -f "$cert" ] && show_cert "$cert" "$(basename "$(dirname "$cert")")"
            done
        else
            warn "No Let's Encrypt directory found"
        fi
        echo ""
        info "Asterisk keys (${KEYS_DIR}):"
        if [ -d "$KEYS_DIR" ]; then
            for cert in "${KEYS_DIR}"/*.crt "${KEYS_DIR}"/*.pem; do
                [ -f "$cert" ] && show_cert "$cert" "$(basename "$cert")"
            done
        else
            warn "Asterisk keys directory not found"
        fi ;;
esac
