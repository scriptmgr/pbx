#!/bin/bash
set -euo pipefail

SCRIPT_VERSION="${SCRIPT_VERSION:-3.0}"
case "${1:-}" in
    --version|-V) printf "%s v%s\n" "$(basename "$0")" "${SCRIPT_VERSION}"; exit 0 ;;
esac
if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
    RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
else
    RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"
    YELLOW="$(printf '\033[1;33m')"; BLUE="$(printf '\033[0;34m')"
    CYAN="$(printf '\033[0;36m')"; BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
fi
ok()   { printf "${GREEN}%s${NC}\n"   "$*"; }
info() { printf "${BLUE}%s${NC}\n"    "$*"; }
warn() { printf "${YELLOW}%s${NC}\n"  "$*"; }
err()  { printf "${RED}%s${NC}\n"     "$*" >&2; }
hdr()  { printf "\n${BOLD}%s${NC}\n" "$*"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

SSHD_CONFIG="/etc/ssh/sshd_config"
AUTH_KEYS="/root/.ssh/authorized_keys"
SSH_PORT=$(grep -E '^Port ' "$SSHD_CONFIG" 2>/dev/null | awk '{print $2}' | head -1 || true)
SSH_PORT="${SSH_PORT:-22}"
SESSION_IP=$(echo "${SSH_CLIENT:-}" | awk '{print $1}' || true)

usage() {
    printf "Usage: pbx-ssh [options]\n\nSSH security management.\n\nOptions:\n"
    printf "  (no args)         Show current SSH config\n"
    printf "  --harden          Disable root password login, enable pubkey, change port\n"
    printf "  --port NEW_PORT   Change SSH port\n"
    printf "  --add-key KEY     Add SSH public key to authorized_keys\n"
    printf "  --help (alias: -h)         Show help
  --version (alias: -V)  Show version\n"; exit 0
}

restart_sshd() {
    systemctl restart sshd 2>/dev/null || systemctl restart ssh 2>/dev/null || \
    service sshd restart 2>/dev/null  || service ssh restart 2>/dev/null  || \
    warn "Could not restart SSH daemon"
}

case "${1:-}" in
    --help|-h) usage ;;
    --harden)
        hdr "Hardening SSH configuration"
        [ -n "$SESSION_IP" ] && {
            info "Session IP ${SESSION_IP} will remain accessible"
            iptables -I INPUT 1 -s "$SESSION_IP" -p tcp --dport "$SSH_PORT" -j ACCEPT 2>/dev/null || true
        }
        sed -i 's/^#*PermitRootLogin.*/PermitRootLogin prohibit-password/' "$SSHD_CONFIG"
        sed -i 's/^#*PubkeyAuthentication.*/PubkeyAuthentication yes/'     "$SSHD_CONFIG"
        sed -i 's/^PasswordAuthentication yes/PasswordAuthentication no/'  "$SSHD_CONFIG"
        printf "New SSH port (current: %s, Enter to keep): " "$SSH_PORT"; read -r NP
        if [ -n "$NP" ] && [ "$NP" != "$SSH_PORT" ]; then
            sed -i "s/^#*Port .*/Port ${NP}/" "$SSHD_CONFIG"
            grep -q "^Port " "$SSHD_CONFIG" || echo "Port ${NP}" >> "$SSHD_CONFIG"
            iptables -I INPUT 1 -p tcp --dport "$NP" -j ACCEPT 2>/dev/null || true
            ok "SSH port changed to ${NP}"
        fi
        restart_sshd && ok "SSH hardened" ;;
    --port)
        NP="${2:-}"; [ -z "$NP" ] && { err "--port requires a port number"; exit 1; }
        [ -n "$SESSION_IP" ] && {
            info "Whitelisting session IP ${SESSION_IP} for new port ${NP}"
            iptables -I INPUT 1 -s "$SESSION_IP" -p tcp --dport "$NP" -j ACCEPT 2>/dev/null || true
        }
        sed -i "s/^#*Port .*/Port ${NP}/" "$SSHD_CONFIG"
        grep -q "^Port " "$SSHD_CONFIG" || echo "Port ${NP}" >> "$SSHD_CONFIG"
        iptables -I INPUT 1 -p tcp --dport "$NP" -j ACCEPT 2>/dev/null || true
        [ -f /etc/fail2ban/jail.local ] && \
            sed -i "s/^port\s*=.*/port = ${NP}/" /etc/fail2ban/jail.local 2>/dev/null || true
        restart_sshd && ok "SSH port changed to ${NP}" ;;
    --add-key)
        KEY="${2:-}"; [ -z "$KEY" ] && { err "--add-key requires a public key string"; exit 1; }
        mkdir -p /root/.ssh; chmod 700 /root/.ssh
        touch "$AUTH_KEYS"; chmod 600 "$AUTH_KEYS"
        echo "$KEY" >> "$AUTH_KEYS" && ok "Key added to ${AUTH_KEYS}" ;;
    *)
        hdr "Current SSH Configuration"
        printf "  Config file     : %s\n" "$SSHD_CONFIG"
        printf "  Port            : %s\n" "$SSH_PORT"
        printf "  PermitRootLogin : %s\n" \
            "$(grep -E '^PermitRootLogin' "$SSHD_CONFIG" 2>/dev/null | awk '{print $2}' || echo 'default')"
        printf "  PubkeyAuth      : %s\n" \
            "$(grep -E '^PubkeyAuthentication' "$SSHD_CONFIG" 2>/dev/null | awk '{print $2}' || echo 'default')"
        printf "  PasswordAuth    : %s\n" \
            "$(grep -E '^PasswordAuthentication' "$SSHD_CONFIG" 2>/dev/null | awk '{print $2}' || echo 'default')"
        [ -n "$SESSION_IP" ] && printf "  Session IP      : %s\n" "$SESSION_IP" || true ;;
esac
