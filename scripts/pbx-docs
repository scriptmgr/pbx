#!/bin/bash
set -euo pipefail
if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
    RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
else
    RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"
    YELLOW="$(printf '\033[1;33m')"; BLUE="$(printf '\033[0;34m')"
    CYAN="$(printf '\033[0;36m')"; BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
fi
ok()   { printf "${GREEN}%s${NC}\n"   "$*"; }
info() { printf "${BLUE}%s${NC}\n"    "$*"; }
warn() { printf "${YELLOW}%s${NC}\n"  "$*"; }
err()  { printf "${RED}%s${NC}\n"     "$*" >&2; }
hdr()  { printf "\n${BOLD}%s${NC}\n" "$*"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ -f /etc/pbx/pbx_passwords ] && . /etc/pbx/pbx_passwords 2>/dev/null || true
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }
WEB_ROOT="${WEB_ROOT:-/var/www/apache/pbx}"

usage() {
    printf "Usage: pbx-docs [options]\n\nDocumentation and quick reference.\n\nOptions:\n"
    printf "  (no args)     Full quick-reference guide\n"
    printf "  --extensions  Demo extensions and feature codes\n"
    printf "  --scripts     List all pbx-* management scripts\n"
    printf "  --urls        Show web interface URLs\n"
    printf "  --dialplan    Show Asterisk dialplan\n"
    printf "  --modules     List FreePBX modules\n"
    printf "  --help/-h     Show help\n"; exit 0
}

show_extensions() {
    hdr "Demo Extensions"
    printf "  DEMO / 3366    Demo menu and system info\n"
    printf "  123            Speaking clock (time and date)\n"
    printf "  947            Weather report (TTS demo)\n"
    printf "  951 / TODAY    Today's date\n"
    printf "  4747 / LENNY   Telemarketer bot\n"
    printf "  *43            Echo test\n"
    printf "  *469, *470     Conference rooms\n"
    printf "  *97            Voicemail main menu\n"
    printf "  *610           Music on Hold test\n"
    hdr "Feature Codes"
    printf "  *72 / *73      Call forward (enable/disable)\n"
    printf "  *76 / *77      Do Not Disturb (on/off)\n"
    printf "  *78            Call recording toggle\n"
    printf "  *68            Wakeup call service\n"
    printf "  *500           Call pickup\n"
    printf "  *501           Directed call pickup\n"
    printf "  *41            Caller ID test\n"
    printf "  *65            Extension status\n"
}

show_scripts() {
    hdr "PBX Management Scripts"
    printf "  pbx-status      Full system status\n"
    printf "  pbx-restart     Safe service restart\n"
    printf "  pbx-repair      FreePBX repair sequence\n"
    printf "  pbx-backup      Manual backup\n"
    printf "  pbx-cleanup     Backup retention\n"
    printf "  pbx-firewall    Firewall management\n"
    printf "  pbx-ssh         SSH security management\n"
    printf "  pbx-security    Security audit\n"
    printf "  pbx-services    Service monitoring\n"
    printf "  pbx-logs        Log management\n"
    printf "  pbx-network     Network diagnostics\n"
    printf "  pbx-ssl         SSL certificate management\n"
    printf "  pbx-passwords   Credential management\n"
    printf "  pbx-docs        Documentation (this script)\n"
    printf "  pbx-moh         Music on Hold management\n"
    printf "  pbx-config      TUI configuration tool\n"
    printf "  pbx-asterisk    Asterisk management\n"
    printf "  pbx-webmin      Webmin management\n"
    printf "  pbx-calls       Active call monitoring\n"
    printf "  pbx-diag        Diagnostic report\n"
    printf "  pbx-recordings  Recording management\n"
    printf "  pbx-update      Self-update from GitHub\n"
    printf "  pbx-trunks      Trunk monitoring\n"
    printf "  pbx-cdr         Call Detail Records\n"
    printf "  pbxstatus       Compact status summary\n"
}

show_urls() {
    hdr "Web Interface URLs"
    IP=$(hostname -I 2>/dev/null | awk '{print $1}')
    [ -n "${PUBLIC_IP:-}" ] && IP="$PUBLIC_IP"
    printf "  FreePBX Admin  : http://%s/admin/\n" "${IP:-localhost}"
    printf "  UCP Portal     : http://%s/ucp/\n" "${IP:-localhost}"
    [ -n "${WEBMIN_PORT:-}" ] && printf "  Webmin         : https://%s:%s/\n" "${IP:-localhost}" "$WEBMIN_PORT"
    hdr "Admin Credentials"
    [ -f /etc/pbx/pbx_passwords ] && grep -E "^FREEPBX_ADMIN" /etc/pbx/pbx_passwords | head -1 || \
        info "Credentials in /etc/pbx/pbx_passwords"
}

case "${1:-}" in
    --help|-h)    usage ;;
    --extensions) show_extensions ;;
    --scripts)    show_scripts ;;
    --urls)       show_urls ;;
    --dialplan)
        command -v asterisk >/dev/null 2>&1 \
            && timeout 10 asterisk -rx "dialplan show" 2>/dev/null \
            || warn "Asterisk unavailable" ;;
    --modules)
        command -v fwconsole >/dev/null 2>&1 \
            && fwconsole ma list 2>/dev/null \
            || warn "fwconsole unavailable" ;;
    *)
        hdr "PBX Quick Reference"
        show_urls; echo ""
        show_extensions; echo ""
        show_scripts ;;
esac
