#!/bin/bash
set -euo pipefail

SCRIPT_VERSION="${SCRIPT_VERSION:-3.0}"
case "${1:-}" in
    --version|-V) printf "%s v%s\n" "$(basename "$0")" "${SCRIPT_VERSION}"; exit 0 ;;
esac
if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
    RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
else
    RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"
    YELLOW="$(printf '\033[1;33m')"; BLUE="$(printf '\033[0;34m')"
    CYAN="$(printf '\033[0;36m')"; BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
fi
ok()   { printf "${GREEN}%s${NC}\n"   "$*"; }
info() { printf "${BLUE}%s${NC}\n"    "$*"; }
warn() { printf "${YELLOW}%s${NC}\n"  "$*"; }
err()  { printf "${RED}%s${NC}\n"     "$*" >&2; }
hdr()  { printf "\n${BOLD}%s${NC}\n" "$*"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ -f /etc/pbx/pbx_passwords ] && . /etc/pbx/pbx_passwords 2>/dev/null || true
[ -z "${MYSQL_ROOT_PASSWORD_FILE:-}" ] && MYSQL_ROOT_PASSWORD_FILE="/etc/pbx/mysql_root_password"
[ -z "${MYSQL_ROOT_PASSWORD:-}" ] && [ -f "${MYSQL_ROOT_PASSWORD_FILE}" ] && \
    MYSQL_ROOT_PASSWORD=$(tr -d '\r\n' < "${MYSQL_ROOT_PASSWORD_FILE}" 2>/dev/null)
[ -z "${ADMIN_USERNAME:-}" ] && ADMIN_USERNAME="${FREEPBX_ADMIN_USERNAME:-administrator}"
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

usage() {
    printf "Usage: pbx-security [--help] [--version]\n\n"
    printf "Run a PBX security audit covering fail2ban, auth failures, open ports,\n"
    printf "Asterisk security logs, firewall rules, default passwords, and TLS status.\n\n"
    printf "Checks:\n"
    printf "  - Fail2ban service and jail state\n"
    printf "  - Recent failed authentication attempts\n"
    printf "  - Listening ports and firewall coverage\n"
    printf "  - Asterisk security log presence\n"
    printf "  - Default password and TLS certificate sanity\n\n"
    printf "Options:\n"
    printf "  --help (alias: -h)     Show help\n"
    printf "  --version (alias: -V)  Show version\n"
    exit 0
}
[ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ] && usage

P=0; W=0; F=0
chk_pass() { ok   "  PASS: $*"; P=$((P+1)); }
chk_warn() { warn "  WARN: $*"; W=$((W+1)); }
chk_fail() { err  "  FAIL: $*"; F=$((F+1)); }

hdr "Fail2ban Status"
if command -v fail2ban-client >/dev/null 2>&1; then
    if systemctl is-active --quiet fail2ban 2>/dev/null; then
        chk_pass "fail2ban is running"
        JAILS=$(fail2ban-client status 2>/dev/null | grep "Jail list:" | sed 's/.*Jail list://;s/,//g')
        for jail in $JAILS; do
            BANNED=$(fail2ban-client status "$jail" 2>/dev/null | grep "Banned IP" | awk -F: '{print $2}' | tr -d ' ')
            info "  Jail ${jail}: banned IPs: ${BANNED:-0}"
        done
    else
        chk_fail "fail2ban is NOT running"
    fi
else
    chk_warn "fail2ban not installed"
fi

hdr "Recent Failed Auth Attempts (last 10)"
AUTH_LOG="/var/log/auth.log"; [ ! -f "$AUTH_LOG" ] && AUTH_LOG="/var/log/secure"
if [ -f "$AUTH_LOG" ]; then
    grep -iE "Failed password|Invalid user|authentication failure" "$AUTH_LOG" 2>/dev/null | tail -10 \
        || info "No recent failures found"
else
    warn "Auth log not found"
fi

hdr "Open Ports"
if command -v ss >/dev/null 2>&1; then
    ss -tlnp 2>/dev/null
elif command -v netstat >/dev/null 2>&1; then
    netstat -tlnp 2>/dev/null
else
    chk_warn "ss/netstat not found"
fi

hdr "Asterisk Security Log"
SECLOG="/var/log/asterisk/security"
if [ -f "$SECLOG" ]; then tail -20 "$SECLOG"
else warn "Security log not found: $SECLOG"; fi

hdr "Firewall Rules Check"
if command -v iptables >/dev/null 2>&1; then
    RC=$(iptables -L INPUT -n 2>/dev/null | grep -cE "^ACCEPT|^DROP|^REJECT" || echo 0)
    [ "$RC" -gt 2 ] \
        && chk_pass "iptables has ${RC} INPUT rules" \
        || chk_warn "iptables has only ${RC} INPUT rules - firewall may not be configured"
else
    chk_warn "iptables not found"
fi

hdr "Default Password Check"
if command -v mysql >/dev/null 2>&1; then
    MOPTS=""; [ -n "${MYSQL_ROOT_PASSWORD:-}" ] && MOPTS="-p${MYSQL_ROOT_PASSWORD}"
    # shellcheck disable=SC2086
    AH=$(mysql $MOPTS asterisk 2>/dev/null \
        -sNe "SELECT password_hash FROM userman_users WHERE username='${ADMIN_USERNAME}' LIMIT 1" 2>/dev/null || echo "")
    if [ -n "$AH" ]; then
        echo "$AH" | grep -qE '^\$apr1\$|\$1\$' \
            && chk_warn "Admin password uses weak MD5 hash" \
            || chk_pass "Admin password hash looks non-trivial"
    else
        info "Could not query admin password hash"
    fi
fi

hdr "Security Summary"
printf "  PASS: %s | WARN: %s | FAIL: %s\n" "$P" "$W" "$F"
[ "$F" -gt 0 ] && err "Action required: ${F} security issue(s) found" || true
[ "$W" -gt 0 ] && warn "Review ${W} warning(s)" || true
[ "$F" -eq 0 ] && [ "$W" -eq 0 ] && ok "All security checks passed" || true
[ "$F" -gt 0 ] && exit 2 || exit 0
