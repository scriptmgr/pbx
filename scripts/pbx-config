#!/bin/bash
set -euo pipefail
setup_output() {
    if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
        RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
        USE_EMOJI=0
        SYM_OK="+"; SYM_FAIL="-"
    else
        RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"; YELLOW="$(printf '\033[1;33m')"
        BLUE="$(printf '\033[0;34m')"; CYAN="$(printf '\033[0;36m')"
        BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
        USE_EMOJI=1
        SYM_OK="✓"; SYM_FAIL="✗"
    fi
}
setup_output
e() { [ "$USE_EMOJI" = "1" ] && printf "%s " "$1" || true; }
_strip_e() { [ "${USE_EMOJI:-0}" = "1" ] && printf '%s' "$*" || printf '%s' "$*" | tr -dc '-'; }
ok()   { local m; m=$(_strip_e "$*"); printf "%s${GREEN}%s${NC}
" "$(e ✅)" "${m}"; }
info() { local m; m=$(_strip_e "$*"); printf "%s${BLUE}%s${NC}
"  "$(e ℹ️ )" "${m}"; }
warn() { local m; m=$(_strip_e "$*"); printf "%s${YELLOW}%s${NC}
" "$(e ⚠️ )" "${m}"; }
err()  { local m; m=$(_strip_e "$*"); printf "%s${RED}%s${NC}
" "$(e ❌)" "${m}" >&2; }
hdr()  { local m; m=$(_strip_e "$*"); printf "
${BOLD}%s%s${NC}
" "$(e 🔧)" "${m}"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
WEB_ROOT="${WEB_ROOT:-/var/www/apache/pbx}"
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

usage() {
    printf "Usage: pbx-config\n\nTUI configuration tool for PBX.\n\nOptions:\n"
    printf "  --help/-h  Show help\n"; exit 0
}
[ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ] && usage

# Detect TUI tool
if command -v dialog >/dev/null 2>&1; then
    TUI="dialog"
elif command -v whiptail >/dev/null 2>&1; then
    TUI="whiptail"
else
    TUI="text"
fi

# ---------------------------------------------------------------------------
# Signal handling — restore terminal on any exit, redraw dialog on resize
# ---------------------------------------------------------------------------
_tui_cleanup() {
    # Clear dialog artifacts and restore terminal to a sane state
    [ "$TUI" != "text" ] && { "$TUI" --clear 2>/dev/null || true; } || true
    stty sane 2>/dev/null || true
    clear
}
_tui_resize() {
    # SIGWINCH: terminal resized — let the next dialog call re-read dimensions
    # (dialog re-reads $LINES/$COLUMNS on each invocation, so no explicit action
    # is needed; we just log it to avoid the default "killed by signal" message)
    :
}
trap '_tui_cleanup' EXIT
trap '_tui_cleanup; exit 130' INT TERM HUP
trap '_tui_resize'  WINCH

menu() {
    local title="$1" prompt="$2"; shift 2
    if [ "$TUI" = "dialog" ] || [ "$TUI" = "whiptail" ]; then
        "$TUI" --stdout --menu "$prompt" 22 70 12 "$@" 2>/dev/null
    else
        printf "\n%s\n%s\n" "$title" "$prompt"
        local i=1
        for arg in "$@"; do
            if [ $((i % 2)) -eq 1 ]; then printf "  %s) " "$arg"
            else printf "%s\n" "$arg"; fi
            i=$((i+1))
        done
        printf "Choice: "; read -r CHOICE; printf '%s' "$CHOICE"
    fi
}

input() {
    local prompt="$1" default="$2"
    if [ "$TUI" = "dialog" ] || [ "$TUI" = "whiptail" ]; then
        "$TUI" --stdout --inputbox "$prompt" 8 60 "$default" 2>/dev/null
    else
        printf "%s [%s]: " "$prompt" "$default"
        read -r VAL; printf '%s' "${VAL:-$default}"
    fi
}

gen_pass() { tr -dc 'A-Za-z0-9' < /dev/urandom 2>/dev/null | head -c 12 || openssl rand -base64 12 2>/dev/null | tr -d '/+='; }

add_extension() {
    EXT=$(input "Extension number" "")
    [ -z "$EXT" ] && return
    NAME=$(input "Display name" "Extension $EXT")
    PASS=$(input "SIP password (blank=auto)" "")
    [ -z "$PASS" ] && PASS=$(gen_pass)
    hdr "Adding extension ${EXT}"
    if command -v fwconsole >/dev/null 2>&1; then
        fwconsole extension --add --ext "$EXT" --name "$NAME" --password "$PASS" 2>/dev/null \
            && ok "Extension $EXT ($NAME) added" \
            || warn "fwconsole extension add failed; writing to pjsip_wizard.conf"
    fi
    CONF="/etc/asterisk/pjsip_wizard.conf"
    printf "\n[%s](dp_default)\ntype=wizard\ndisplay_name=%s\nhas_hint=yes\nhint_exten=%s\naors/max_contacts=5\nendpoint/allow=!all,ulaw,alaw\naors/qualify_frequency=30\nauth/auth_type=userpass\nauth/username=%s\nauth/password=%s\n" \
        "$EXT" "$NAME" "$EXT" "$EXT" "$PASS" >> "$CONF"
    info "Password for ${EXT}: ${PASS}"
    fwconsole reload 2>/dev/null || true
}

add_trunk() {
    TTYPE=$(menu "Trunk Type" "Select VoIP provider:" \
        "voip.ms" "VoIP.ms" \
        "flowroute" "Flowroute" \
        "telnyx" "Telnyx" \
        "twilio" "Twilio" \
        "custom" "Custom SIP provider")
    [ -z "$TTYPE" ] && return
    TNAME=$(input "Trunk name" "$TTYPE-trunk")
    USER=$(input "Username/Account" "")
    PASS=$(input "Password/Auth" "")
    case "$TTYPE" in
        voip.ms)   HOST="chicago1.voip.ms"; PORT=5060 ;;
        flowroute)  HOST="us-east-va.sip.flowroute.com"; PORT=5060 ;;
        telnyx)     HOST="sip.telnyx.com"; PORT=5060 ;;
        twilio)     HOST="pstn.twilio.com"; PORT=5060 ;;
        custom)
            HOST=$(input "SIP host" "sip.provider.com")
            PORT=$(input "SIP port" "5060") ;;
    esac
    hdr "Adding trunk ${TNAME}"
    CONF="/etc/asterisk/pjsip_wizard.conf"
    printf "\n[%s]\ntype=wizard\nregisters=yes\nsends_auth=yes\nsends_registrations=yes\nremote_hosts=%s:%s\noutbound_auth/auth_type=userpass\noutbound_auth/username=%s\noutbound_auth/password=%s\n" \
        "$TNAME" "$HOST" "$PORT" "$USER" "$PASS" >> "$CONF"
    ok "Trunk ${TNAME} added (${HOST})"
    fwconsole reload 2>/dev/null || true
}

add_inbound() {
    DID=$(input "DID number (leave blank for any)" "")
    DEST=$(input "Destination extension" "")
    [ -z "$DEST" ] && return
    hdr "Adding inbound route"
    CONF="/etc/asterisk/extensions_custom.conf"
    if [ -n "$DID" ]; then
        printf "\nexten => %s,1,Goto(from-did-direct,%s,1)\n" "$DID" "$DEST" >> "$CONF"
        ok "Inbound route: DID ${DID} -> extension ${DEST}"
    else
        printf "\nexten => _.,1,Goto(from-did-direct,%s,1)\n" "$DEST" >> "$CONF"
        ok "Inbound route: any DID -> extension ${DEST}"
    fi
    timeout 5 asterisk -rx "dialplan reload" 2>/dev/null || true
}

add_outbound() {
    RNAME=$(input "Route name" "outbound-main")
    PATTERN=$(input "Dial pattern (e.g. _1NXXNXXXXXX)" "_1NXXNXXXXXX")
    TRUNK=$(input "Trunk name" "")
    [ -z "$TRUNK" ] && return
    hdr "Adding outbound route"
    CONF="/etc/asterisk/extensions_custom.conf"
    printf "\nexten => %s,1,Dial(PJSIP/\${EXTEN}@%s)\nexten => %s,n,Hangup()\n" \
        "$PATTERN" "$TRUNK" "$PATTERN" >> "$CONF"
    ok "Outbound route: ${PATTERN} via ${TRUNK}"
    timeout 5 asterisk -rx "dialplan reload" 2>/dev/null || true
}

apply_reload() {
    hdr "Applying configuration"
    command -v fwconsole >/dev/null 2>&1 && fwconsole reload 2>/dev/null && ok "FreePBX reloaded" || \
        timeout 5 asterisk -rx "core reload" 2>/dev/null && ok "Asterisk reloaded" || \
        warn "Could not reload"
}

view_extensions() {
    hdr "Current Extensions"
    command -v asterisk >/dev/null 2>&1 \
        && timeout 5 asterisk -rx "pjsip show endpoints" 2>/dev/null \
        || cat /etc/asterisk/pjsip_wizard.conf 2>/dev/null | grep '^\[' | grep -v 'template\|wizard'
}

view_trunks() {
    hdr "Current Trunks"
    command -v asterisk >/dev/null 2>&1 \
        && timeout 5 asterisk -rx "pjsip show registrations" 2>/dev/null \
        || cat /etc/asterisk/pjsip_wizard.conf 2>/dev/null | grep '^\[' | grep 'trunk'
}

while true; do
    CHOICE=$(menu "PBX Config" "PBX Configuration Tool - Select action:" \
        "1" "Add PJSIP Extension" \
        "2" "Add SIP Trunk" \
        "3" "Add Inbound Route (DID -> extension)" \
        "4" "Add Outbound Route (dial pattern -> trunk)" \
        "5" "View Extensions" \
        "6" "View Trunks" \
        "7" "Apply & Reload" \
        "8" "Exit")
    [ -z "$CHOICE" ] && break
    case "$CHOICE" in
        1) add_extension ;;
        2) add_trunk ;;
        3) add_inbound ;;
        4) add_outbound ;;
        5) view_extensions ;;
        6) view_trunks ;;
        7) apply_reload ;;
        8|q|Q) break ;;
    esac
    [ "$TUI" = "text" ] && printf "\nPress Enter to continue..."; [ "$TUI" = "text" ] && read -r _
done

ok "pbx-config done"
