#!/bin/bash
# pbx-ip-checker - Public IP change detector
# Cron example: */10 5-22 * * * /usr/local/bin/pbx-ip-checker
set -euo pipefail

SCRIPT_VERSION="${SCRIPT_VERSION:-3.0}"
case "${1:-}" in
    --version|-V) printf "%s v%s\n" "$(basename "$0")" "${SCRIPT_VERSION}"; exit 0 ;;
esac

if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
    RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
else
    RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"
    YELLOW="$(printf '\033[1;33m')"; BLUE="$(printf '\033[0;34m')"
    CYAN="$(printf '\033[0;36m')"; BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
fi
ok()   { printf "${GREEN}%s${NC}\n"   "$*"; }
info() { printf "${BLUE}%s${NC}\n"    "$*"; }
warn() { printf "${YELLOW}%s${NC}\n"  "$*"; }
err()  { printf "${RED}%s${NC}\n"     "$*" >&2; }
hdr()  { printf "\n${BOLD}%s${NC}\n" "$*"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

IP_FILE="/etc/pbx/public-ip"
LOG_FILE="/var/log/pbx/ip-checker.log"
WHITELIST_FILE="/etc/pbx/whitelist.txt"
SSH_PORT_FILE="/etc/pbx/ssh-port"

mkdir -p "$(dirname "$LOG_FILE")"

log_raw() { printf "%s\n" "$*" | sed 's/\x1b\[[0-9;]*m//g' >> "${LOG_FILE}"; }

usage() {
    printf "Usage: pbx-ip-checker [--show]\n\n"
    printf "Detects public IP address changes and updates the firewall whitelist.\n\n"
    printf "Storage:\n"
    printf "  /etc/pbx/public-ip         Stores the last known public IP\n"
    printf "  /var/log/pbx/ip-checker.log  Change events logged here\n\n"
    printf "Cron example:\n"
    printf "  */10 5-22 * * * /usr/local/bin/pbx-ip-checker\n\n"
    printf "Behavior:\n"
    printf "  1. Detect current public IP via multiple providers\n"
    printf "  2. Compare with stored IP in /etc/pbx/public-ip\n"
    printf "  3. If changed: update iptables ACCEPT rule, log the change\n"
    printf "  4. If unchanged: exit silently\n\n"
    printf "Options:\n"
    printf "  --show     Show current stored IP\n"
    printf "  --help (alias: -h)     Show help\n"
    printf "  --version (alias: -V)  Show version\n"
    exit 0
}

get_public_ip() {
    local ip=""
    for url in "https://api.ipify.org" "https://ifconfig.me" \
               "https://icanhazip.com" "https://ident.me"; do
        ip=$(curl -s --max-time 8 "$url" 2>/dev/null | tr -d '[:space:]')
        case "$ip" in
            [0-9]*.[0-9]*.[0-9]*.[0-9]*)
                printf '%s' "$ip"
                return 0
                ;;
        esac
    done
    return 1
}

update_iptables() {
    local old_ip="$1" new_ip="$2"
    # Remove old dynamic rule if present
    if [ -n "$old_ip" ] && iptables -C INPUT -s "$old_ip" -j ACCEPT \
           -m comment --comment "pbx-dynamic-ip" 2>/dev/null; then
        iptables -D INPUT -s "$old_ip" -j ACCEPT \
            -m comment --comment "pbx-dynamic-ip" 2>/dev/null || true
        log_raw "Removed iptables rule for old IP: $old_ip"
    fi
    # Add new IP rule at position 1
    if iptables -I INPUT 1 -s "$new_ip" -j ACCEPT \
            -m comment --comment "pbx-dynamic-ip" 2>/dev/null; then
        log_raw "Added iptables ACCEPT for new IP: $new_ip"
    fi
    # Ensure SSH port remains open
    ssh_port=$(cat "$SSH_PORT_FILE" 2>/dev/null || printf '22')
    iptables -I INPUT 2 -p tcp --dport "$ssh_port" -j ACCEPT \
        -m comment --comment "ssh-safety" 2>/dev/null || true
}

update_whitelist() {
    local old_ip="$1" new_ip="$2"
    mkdir -p "$(dirname "$WHITELIST_FILE")"
    if [ -f "$WHITELIST_FILE" ] && [ -n "$old_ip" ]; then
        sed -i "/^${old_ip}[[:space:]]*pbx-dynamic-ip/d" "$WHITELIST_FILE" 2>/dev/null || true
    fi
    printf "%s  pbx-dynamic-ip\n" "$new_ip" >> "$WHITELIST_FILE"
}

case "${1:-}" in
    --help|-h) usage ;;
    --show)
        if [ -f "$IP_FILE" ]; then
            printf "Stored public IP: %s\n" "$(cat "$IP_FILE")"
        else
            info "No stored IP found"
        fi
        exit 0
        ;;
esac

mkdir -p "$(dirname "$IP_FILE")"

current_ip=$(get_public_ip) || {
    log_raw "[$(date '+%Y-%m-%d %H:%M:%S')] ERROR: Could not determine public IP"
    exit 0  # Don't fail cron on transient network error
}

old_ip=$(cat "$IP_FILE" 2>/dev/null || true)

if [ "$current_ip" = "$old_ip" ]; then
    exit 0
fi

# IP changed
log_raw "[$(date '+%Y-%m-%d %H:%M:%S')] IP changed: ${old_ip:-none} -> ${current_ip}"
warn "Public IP changed: ${old_ip:-none} -> ${current_ip}"

printf '%s' "$current_ip" > "$IP_FILE"

command -v iptables >/dev/null 2>&1 && update_iptables "${old_ip:-}" "$current_ip"
update_whitelist "${old_ip:-}" "$current_ip"

ok "IP updated to $current_ip"
