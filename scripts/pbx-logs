#!/bin/bash
set -euo pipefail
if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
    RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
else
    RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"
    YELLOW="$(printf '\033[1;33m')"; BLUE="$(printf '\033[0;34m')"
    CYAN="$(printf '\033[0;36m')"; BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
fi
ok()   { printf "${GREEN}%s${NC}\n"   "$*"; }
info() { printf "${BLUE}%s${NC}\n"    "$*"; }
warn() { printf "${YELLOW}%s${NC}\n"  "$*"; }
err()  { printf "${RED}%s${NC}\n"     "$*" >&2; }
hdr()  { printf "\n${BOLD}%s${NC}\n" "$*"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

usage() {
    printf "Usage: pbx-logs [options]\n\nLog management and viewing.\n\nOptions:\n"
    printf "  (no args)         Show recent Asterisk log entries (last 100 lines)\n"
    printf "  --follow/-f       Tail /var/log/asterisk/full (live, Ctrl+C to stop)\n"
    printf "  --error           Show security and auth error logs\n"
    printf "  --calls           Show CDR call log\n"
    printf "  --install         Show installation log\n"
    printf "  --apache          Show Apache/HTTPD error log\n"
    printf "  --clear           Clear old log entries (>30 days)\n"
    printf "  --search PATTERN  Search for pattern in Asterisk logs\n"
    printf "  --help/-h         Show help\n"; exit 0
}

case "${1:-}" in
    --help|-h) usage ;;
    --error)
        hdr "Security and Error Logs"
        info "Asterisk security log:"
        tail -50 /var/log/asterisk/security 2>/dev/null || warn "Security log not found"
        echo ""
        info "Auth log:"
        AUTH_LOG="/var/log/auth.log"; [ ! -f "$AUTH_LOG" ] && AUTH_LOG="/var/log/secure"
        tail -30 "$AUTH_LOG" 2>/dev/null || warn "Auth log not found" ;;
    --calls)
        hdr "Recent Call Records"
        CDR="/var/log/asterisk/cdr-csv/Master.csv"
        if [ -f "$CDR" ]; then
            printf "accountcode,src,dst,dcontext,clid,channel,dstchannel,lastapp,lastdata,start,answer,end,duration,billsec,disposition\n"
            tail -20 "$CDR"
        else
            warn "CDR file not found: $CDR"
        fi ;;
    --install)
        hdr "PBX Installation Log"
        if [ -f /var/log/pbx-install.log ]; then cat /var/log/pbx-install.log
        else warn "Install log not found: /var/log/pbx-install.log"; fi ;;
    --apache)
        hdr "Apache/HTTPD Error Log"
        for logfile in /var/log/httpd/error_log /var/log/apache2/error.log /var/log/apache2/error_log; do
            if [ -f "$logfile" ]; then tail -50 "$logfile"; break; fi
        done ;;
    --clear)
        hdr "Clearing old log entries"
        if command -v asterisk >/dev/null 2>&1; then
            timeout 5 asterisk -rx "logger rotate" 2>/dev/null && ok "Asterisk logs rotated"
        fi
        find /var/log/asterisk/ -name "*.log" -mtime +30 -delete 2>/dev/null && ok "Old Asterisk logs removed" ;;
    --search)
        PATTERN="${2:-}"; [ -z "$PATTERN" ] && { err "--search requires a PATTERN"; exit 1; }
        hdr "Searching for: ${PATTERN}"
        AUTH_LOG="/var/log/auth.log"; [ ! -f "$AUTH_LOG" ] && AUTH_LOG="/var/log/secure"
        grep -i "$PATTERN" /var/log/asterisk/full /var/log/asterisk/security "$AUTH_LOG" 2>/dev/null | tail -50 ;;
    --follow|-f)
        hdr "Asterisk Log — Live (Ctrl+C to stop)"
        LOGFILE="/var/log/asterisk/full"
        if [ -f "$LOGFILE" ]; then tail -f "$LOGFILE"
        else warn "Log file not found: $LOGFILE"; fi ;;
    *)
        hdr "Asterisk Log (recent entries)"
        LOGFILE="/var/log/asterisk/full"
        if [ -f "$LOGFILE" ]; then tail -100 "$LOGFILE"
        else warn "Log file not found: $LOGFILE"; fi ;;
esac
