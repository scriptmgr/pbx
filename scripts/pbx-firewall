#!/bin/bash
setup_output() {
    if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
        RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
        USE_EMOJI=0
    else
        RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"; YELLOW="$(printf '\033[1;33m')"
        BLUE="$(printf '\033[0;34m')"; CYAN="$(printf '\033[0;36m')"
        BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
        USE_EMOJI=1
    fi
}
setup_output
e() { [ "$USE_EMOJI" = "1" ] && printf "%s " "$1" || true; }
ok()   { printf "%s${GREEN}%s${NC}\n" "$(e ✅)" "$*"; }
info() { printf "%s${BLUE}%s${NC}\n"  "$(e ℹ️ )" "$*"; }
warn() { printf "%s${YELLOW}%s${NC}\n" "$(e ⚠️ )" "$*"; }
err()  { printf "%s${RED}%s${NC}\n" "$(e ❌)" "$*" >&2; }
hdr()  { printf "\n${BOLD}%s%s${NC}\n" "$(e 🔧)" "$*"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

usage() {
    printf "Usage: pbx-firewall [options]\n\nFirewall management.\n\nOptions:\n"
    printf "  (no args)       Show current status\n"
    printf "  --allow IP      Whitelist an IP\n  --deny IP       Block an IP\n"
    printf "  --ssh           Show SSH-specific rules\n"
    printf "  --reset         Flush INPUT, restore defaults (keeps SSH open)\n"
    printf "  --show-banned   Show fail2ban banned IPs\n  --help/-h       Show help\n"; exit 0
}

SSH_PORT=$(grep -E '^Port ' /etc/ssh/sshd_config 2>/dev/null | awk '{print $2}' | head -1)
SSH_PORT="${SSH_PORT:-22}"

case "${1:-}" in
    --help|-h) usage ;;
    --allow)
        IP="${2:-}"; COMMENT="${3:-manual whitelist}"
        [ -z "$IP" ] && { err "--allow requires an IP"; exit 1; }
        if command -v firewall-cmd >/dev/null 2>&1 && systemctl is-active --quiet firewalld 2>/dev/null; then
            firewall-cmd --permanent --add-rich-rule="rule family='ipv4' source address='${IP}' accept" 2>/dev/null \
                && firewall-cmd --reload 2>/dev/null && ok "Allowed $IP (firewalld)"
        elif command -v ufw >/dev/null 2>&1; then
            ufw allow from "$IP" comment "$COMMENT" 2>/dev/null && ok "Allowed $IP (ufw)"
        elif command -v iptables >/dev/null 2>&1; then
            iptables -I INPUT 1 -s "$IP" -j ACCEPT -m comment --comment "$COMMENT" \
                && ok "Allowed $IP (iptables)"
        else
            err "No firewall tool found"
        fi ;;
    --deny)
        IP="${2:-}"; [ -z "$IP" ] && { err "--deny requires an IP"; exit 1; }
        printf "Block %s? May affect active connections. [y/N] " "$IP"; read -r C
        [ "$C" != "y" ] && [ "$C" != "Y" ] && { info "Aborted."; exit 0; }
        command -v iptables >/dev/null 2>&1 \
            && iptables -I INPUT 1 -s "$IP" -j DROP && ok "Blocked $IP" \
            || err "iptables not found" ;;
    --ssh)
        hdr "SSH Firewall Rules (port ${SSH_PORT})"
        command -v iptables >/dev/null 2>&1 \
            && iptables -L INPUT -n --line-numbers 2>/dev/null | grep "$SSH_PORT" \
            || info "No specific SSH iptables rules found" ;;
    --reset)
        hdr "Resetting firewall (SSH port ${SSH_PORT} will remain open)"
        printf "Flush all INPUT rules? [y/N] "; read -r C
        [ "$C" != "y" ] && [ "$C" != "Y" ] && { info "Aborted."; exit 0; }
        if command -v iptables >/dev/null 2>&1; then
            iptables -F INPUT; iptables -P INPUT ACCEPT
            iptables -I INPUT 1 -p tcp --dport "$SSH_PORT" -j ACCEPT
            iptables -A INPUT -m state --state RELATED,ESTABLISHED -j ACCEPT
            iptables -A INPUT -i lo -j ACCEPT
            iptables -A INPUT -p tcp -m multiport --dports 80,443 -j ACCEPT
            iptables -A INPUT -p udp --dport 5060 -j ACCEPT
            iptables -A INPUT -p tcp --dport 5061 -j ACCEPT
            iptables -A INPUT -p udp --dport 10000:20000 -j ACCEPT
            ok "Firewall reset. SSH port ${SSH_PORT} is open."
        fi ;;
    --show-banned)
        hdr "Fail2ban Banned IPs"
        if command -v fail2ban-client >/dev/null 2>&1; then
            JAILS=$(fail2ban-client status 2>/dev/null | grep "Jail list:" | sed 's/.*Jail list://;s/,//g')
            for jail in $JAILS; do
                info "Jail: $jail"
                fail2ban-client status "$jail" 2>/dev/null | grep "Banned IP" || true
            done
        else
            warn "fail2ban-client not found"
        fi ;;
    *)
        hdr "Firewall Status"
        if command -v iptables >/dev/null 2>&1; then
            info "iptables INPUT chain:"
            iptables -L INPUT -n --line-numbers 2>/dev/null || warn "Could not read iptables"
        fi
        if command -v firewall-cmd >/dev/null 2>&1 && systemctl is-active --quiet firewalld 2>/dev/null; then
            info "firewalld:"; firewall-cmd --list-all 2>/dev/null || true
        fi
        if command -v ufw >/dev/null 2>&1; then
            info "ufw status:"; ufw status 2>/dev/null || true
        fi ;;
esac
