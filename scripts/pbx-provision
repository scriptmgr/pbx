#!/bin/bash
# PBX Phone Provisioning Manager
set -euo pipefail

setup_output() {
    if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
        RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
        USE_EMOJI=0
        SYM_OK="+"; SYM_FAIL="-"
    else
        RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"; YELLOW="$(printf '\033[1;33m')"
        BLUE="$(printf '\033[0;34m')"; CYAN="$(printf '\033[0;36m')"
        BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
        USE_EMOJI=1
        SYM_OK="✓"; SYM_FAIL="✗"
    fi
}
setup_output
e() { [ "$USE_EMOJI" = "1" ] && printf "%s " "$1" || true; }
_strip_e() { [ "${USE_EMOJI:-0}" = "1" ] && printf '%s' "$*" || printf '%s' "$*" | tr -dc '-'; }
ok()   { local m; m=$(_strip_e "$*"); printf "%s${GREEN}%s${NC}
" "$(e ✅)" "${m}"; }
info() { local m; m=$(_strip_e "$*"); printf "%s${BLUE}%s${NC}
"  "$(e ℹ️ )" "${m}"; }
warn() { local m; m=$(_strip_e "$*"); printf "%s${YELLOW}%s${NC}
" "$(e ⚠️ )" "${m}"; }
err()  { local m; m=$(_strip_e "$*"); printf "%s${RED}%s${NC}
" "$(e ❌)" "${m}" >&2; }
hdr()  { local m; m=$(_strip_e "$*"); printf "
${BOLD}%s%s${NC}
" "$(e 🔧)" "${m}"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

PBX_IP="${PRIVATE_IP:-$(hostname -I 2>/dev/null | awk '{print $1}')}"
TFTP_ROOT="${TFTP_ROOT:-/var/lib/tftpboot}"
HTTP_ROOT="${HTTP_ROOT:-/var/www/html/provisioning}"

usage() {
    printf "Usage: pbx-provision [command] [args]\n\n"
    printf "Manage phone provisioning via TFTP and HTTP.\n\n"
    printf "Commands:\n"
    printf "  (no args)          Show provisioning status and URLs\n"
    printf "  --setup            Create provisioning directories and enable TFTP\n"
    printf "  --yealink MAC EXT  Create Yealink config for MAC address and extension\n"
    printf "  --list             List provisioned device configs\n"
    printf "  --remove MAC       Remove config for a device MAC address\n"
    printf "  --help/-h          Show help\n\n"
    printf "Examples:\n"
    printf "  pbx-provision --yealink aa:bb:cc:dd:ee:ff 1001\n"
    printf "  pbx-provision --list\n"
    printf "  pbx-provision --remove aa:bb:cc:dd:ee:ff\n"
    exit 0
}

show_status() {
    hdr "Phone Provisioning"
    printf "  TFTP root : %s\n" "$TFTP_ROOT"
    printf "  HTTP root : %s\n" "$HTTP_ROOT"
    printf "  HTTP URL  : http://%s/provisioning/\n" "$PBX_IP"
    printf "  TFTP URL  : tftp://%s/\n" "$PBX_IP"
    echo ""
    # Check TFTP service
    if systemctl is-active --quiet tftp 2>/dev/null || \
       systemctl is-active --quiet tftpd-hpa 2>/dev/null || \
       systemctl is-active --quiet xinetd 2>/dev/null; then
        ok "TFTP service is running"
    else
        warn "TFTP service not running — run: pbx-provision --setup"
    fi
    # Show device count
    if [ -d "$TFTP_ROOT" ]; then
        count=$(find "$TFTP_ROOT" -maxdepth 1 -name "*.cfg" 2>/dev/null | wc -l)
        info "Device configs in TFTP root: ${count}"
    fi
    echo ""
    info "Phone provisioning instructions:"
    printf "  Yealink : Set server URL to tftp://%s/ or http://%s/provisioning/\n" \
        "$PBX_IP" "$PBX_IP"
    printf "  Cisco   : Set TFTP server to %s\n" "$PBX_IP"
    printf "  Grandstream: Set config server to http://%s/provisioning/\n" "$PBX_IP"
}

cmd_setup() {
    hdr "Setting up provisioning directories"
    mkdir -p "$TFTP_ROOT" "$HTTP_ROOT"
    chmod 755 "$TFTP_ROOT" "$HTTP_ROOT"
    ok "Created: $TFTP_ROOT"
    ok "Created: $HTTP_ROOT"
    # Create Yealink base template if not present
    YLINK_TMPL="${TFTP_ROOT}/y000000000000.cfg"
    if [ ! -f "$YLINK_TMPL" ]; then
        cat > "$YLINK_TMPL" << 'YLINK'
#!version:1.0.0.1
## Yealink base template
## Provisioning server: set per-phone MAC config
account.1.enable = 1
account.1.label = PBX
account.1.display_name = PBX Extension
account.1.auth_name =
account.1.user_name =
account.1.password =
account.1.sip_server_host = PBX_IP
account.1.sip_server_port = 5060
phone_setting.time_zone = -5
YLINK
        sed -i "s/PBX_IP/${PBX_IP}/g" "$YLINK_TMPL"
        ok "Yealink base template created: ${YLINK_TMPL}"
    fi
    # Enable TFTP if xinetd is installed
    if command -v xinetd >/dev/null 2>&1 && [ -f /etc/xinetd.d/tftp ]; then
        sed -i 's/disable.*=.*yes/disable = no/' /etc/xinetd.d/tftp 2>/dev/null || true
        systemctl restart xinetd 2>/dev/null && ok "xinetd/TFTP restarted" || warn "Could not restart xinetd"
    elif systemctl list-unit-files 2>/dev/null | grep -q "tftpd-hpa"; then
        systemctl enable --now tftpd-hpa 2>/dev/null && ok "tftpd-hpa enabled" || warn "Could not enable tftpd-hpa"
    else
        warn "No TFTP server found — install tftp-server or tftpd-hpa"
    fi
}

cmd_yealink() {
    MAC="${1:-}"; EXT="${2:-}"
    [ -z "$MAC" ] || [ -z "$EXT" ] && {
        err "Usage: pbx-provision --yealink <MAC> <extension>"
        err "Example: pbx-provision --yealink aa:bb:cc:dd:ee:ff 1001"
        exit 1
    }
    # Normalize MAC: lowercase, no colons/dashes
    MAC_NORM=$(printf '%s' "$MAC" | tr '[:upper:]' '[:lower:]' | tr -d ':- ')
    [ ${#MAC_NORM} -eq 12 ] || { err "Invalid MAC address: ${MAC}"; exit 1; }
    # Get extension password from FreePBX if possible
    EXT_PASS=""
    if command -v mysql >/dev/null 2>&1 && [ -n "${MYSQL_ROOT_PASSWORD:-}" ]; then
        EXT_PASS=$(mysql -u root -p"${MYSQL_ROOT_PASSWORD}" asterisk 2>/dev/null \
            -sNe "SELECT data FROM sip WHERE id='${EXT}' AND keyword='secret' LIMIT 1" 2>/dev/null || true)
    fi
    [ -z "$EXT_PASS" ] && EXT_PASS="changeme"
    CFG_FILE="${TFTP_ROOT}/${MAC_NORM}.cfg"
    mkdir -p "$TFTP_ROOT"
    cat > "$CFG_FILE" << YLINK
#!version:1.0.0.1
## Yealink config for MAC ${MAC_NORM} — Extension ${EXT}
## Generated by pbx-provision on $(date)
account.1.enable = 1
account.1.label = ${EXT}
account.1.display_name = Extension ${EXT}
account.1.auth_name = ${EXT}
account.1.user_name = ${EXT}
account.1.password = ${EXT_PASS}
account.1.sip_server_host = ${PBX_IP}
account.1.sip_server_port = 5060
YLINK
    ok "Yealink config created: ${CFG_FILE}"
    info "MAC: ${MAC_NORM} | Extension: ${EXT} | Server: ${PBX_IP}"
    # Also create HTTP copy
    if [ -d "$HTTP_ROOT" ]; then
        cp "$CFG_FILE" "${HTTP_ROOT}/${MAC_NORM}.cfg" 2>/dev/null && \
            info "HTTP copy: ${HTTP_ROOT}/${MAC_NORM}.cfg"
    fi
    info "Reboot phone or trigger auto-provision to apply"
}

cmd_list() {
    hdr "Provisioned Devices"
    if [ -d "$TFTP_ROOT" ]; then
        found=0
        for f in "${TFTP_ROOT}"/*.cfg; do
            [ -f "$f" ] || continue
            name=$(basename "$f" .cfg)
            [ "$name" = "y000000000000" ] && continue
            printf "  %s\n" "$name"
            found=$((found + 1))
        done
        [ "$found" -eq 0 ] && info "No device configs found in ${TFTP_ROOT}"
    else
        warn "TFTP root not found: ${TFTP_ROOT}"
    fi
}

cmd_remove() {
    MAC="${1:-}"
    [ -z "$MAC" ] && { err "Usage: pbx-provision --remove <MAC>"; exit 1; }
    MAC_NORM=$(printf '%s' "$MAC" | tr '[:upper:]' '[:lower:]' | tr -d ':- ')
    CFG="${TFTP_ROOT}/${MAC_NORM}.cfg"
    if [ -f "$CFG" ]; then
        rm -f "$CFG"
        ok "Removed: ${CFG}"
        rm -f "${HTTP_ROOT}/${MAC_NORM}.cfg" 2>/dev/null || true
    else
        warn "Config not found: ${CFG}"
    fi
}

case "${1:-}" in
    --help|-h) usage ;;
    --setup)   cmd_setup ;;
    --yealink) shift; cmd_yealink "$@" ;;
    --list)    cmd_list ;;
    --remove)  shift; cmd_remove "$@" ;;
    "")        show_status ;;
    *)
        err "Unknown option: ${1}"
        printf "Run 'pbx-provision --help' for usage.\n" >&2
        exit 1
        ;;
esac
