#!/bin/bash
# pbx-tftp — Manage the PBX TFTP server for phone provisioning
# Usage: pbx-tftp [status|start|stop|restart|list|add-device|set-server|--help]
set -euo pipefail

SCRIPT_VERSION="${SCRIPT_VERSION:-3.0}"
case "${1:-}" in
    --version|-V) printf "%s v%s\n" "$(basename "$0")" "${SCRIPT_VERSION}"; exit 0 ;;
esac

# ---------------------------------------------------------------------------
# Output helpers
# ---------------------------------------------------------------------------
if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ]; then
    RED=""; GREEN=""; YELLOW=""; CYAN=""; BOLD=""; NC=""
    SYM_OK="[  OK  ]"; SYM_FAIL="[ FAIL ]"; SYM_WARN="[ WARN ]"
else
    RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"
    YELLOW="$(printf '\033[1;33m')"; CYAN="$(printf '\033[0;36m')"
    BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
    SYM_OK="${GREEN}[  OK  ]${NC}"; SYM_FAIL="${RED}[ FAIL ]${NC}"; SYM_WARN="${YELLOW}[ WARN ]${NC}"
fi

ok()   { printf "${GREEN}%s${NC}\n" "$*"; }
warn() { printf "${YELLOW}%s${NC}\n" "$*"; }
err()  { printf "${RED}%s${NC}\n" "$*" >&2; }
hdr()  { printf "\n${BOLD}%s${NC}\n%s\n" "$*" "$(printf '%0.s─' $(seq 1 60))"; }

# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------
TFTP_ROOT="/var/lib/tftpboot"
ENV_FILE="/etc/pbx/.env"
[ -f "${ENV_FILE}" ] && . "${ENV_FILE}" 2>/dev/null || true
PRIMARY_IP="${PRIMARY_IP:-${PRIVATE_IP:-$(ip -4 route get 8.8.8.8 2>/dev/null | awk '/src/{for(i=1;i<=NF;i++) if($i=="src"){print $(i+1); exit}}')}}"

unit_exists() {
    command -v systemctl >/dev/null 2>&1 || return 1
    local state
    state=$(systemctl show -p LoadState --value "$1" 2>/dev/null || true)
    [ -n "${state}" ] && [ "${state}" != "not-found" ]
}

detect_tftp_unit() {
    local unit
    if ! command -v systemctl >/dev/null 2>&1; then
        [ -x /etc/init.d/xinetd ] && { printf 'xinetd'; return 0; }
        [ -x /etc/init.d/tftp ] && { printf 'tftp'; return 0; }
    fi
    for unit in tftpd-hpa tftp.socket tftp xinetd; do
        unit_exists "${unit}" && { printf '%s' "${unit}"; return 0; }
    done
    printf 'tftp'
}

TFTP_SVC="$(detect_tftp_unit)"

[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

svc_run() {
    local action="$1"
    if command -v systemctl >/dev/null 2>&1; then
        systemctl "${action}" "${TFTP_SVC}" 2>/dev/null
    else
        service "${TFTP_SVC}" "${action}" 2>/dev/null
    fi
}

# ---------------------------------------------------------------------------
# Functions
# ---------------------------------------------------------------------------
svc_state() {
    local state
    if command -v systemctl >/dev/null 2>&1; then
        state=$(systemctl is-active "${TFTP_SVC}" 2>/dev/null || true)
    else
        service "${TFTP_SVC}" status >/dev/null 2>&1 && state="active" || state="inactive"
    fi
    [ -n "${state}" ] || state="inactive"
    printf '%s' "${state}"
}

cmd_status() {
    hdr "TFTP Server Status"
    local state
    state=$(svc_state)
    if [ "${state}" = "active" ]; then
        printf "  Service       %s %s\n" "${SYM_OK}" "${TFTP_SVC}"
    else
        printf "  Service       %s %s (%s)\n" "${SYM_FAIL}" "${TFTP_SVC}" "${state}"
    fi
    printf "  TFTP Root     %s\n" "${TFTP_ROOT}"
    printf "  Server IP     %s\n" "${PRIMARY_IP:-unknown}"
    printf "  Port          69/udp\n"

    hdr "Provisioning Directories"
    for vendor in yealink polycom grandstream cisco snom; do
        local dir="${TFTP_ROOT}/${vendor}"
        if [ -d "${dir}" ]; then
            local count
            count=$(find "${dir}" -maxdepth 1 -name "*.cfg" 2>/dev/null | wc -l | tr -d ' ')
            printf "  %-14s %s (%s config files)\n" "${vendor}" "${SYM_OK}" "${count}"
        else
            printf "  %-14s (not created)\n" "${vendor}"
        fi
    done

    hdr "Device Config Files"
    local files
    files=$(find "${TFTP_ROOT}" -maxdepth 2 -name "*.cfg" 2>/dev/null | sort)
    if [ -n "${files}" ]; then
        printf '%s\n' "${files}" | while read -r f; do
            printf "  %s\n" "${f#${TFTP_ROOT}/}"
        done
    else
        warn "  No .cfg files found in ${TFTP_ROOT}"
    fi
}

cmd_start() {
    ok "Starting ${TFTP_SVC}..."
    svc_run start && ok "Started" || err "Failed to start ${TFTP_SVC}"
}

cmd_stop() {
    warn "Stopping ${TFTP_SVC}..."
    svc_run stop && ok "Stopped" || err "Failed to stop ${TFTP_SVC}"
}

cmd_restart() {
    warn "Restarting ${TFTP_SVC}..."
    svc_run restart && ok "Restarted" || err "Failed to restart ${TFTP_SVC}"
}

cmd_list() {
    hdr "TFTP Files  (${TFTP_ROOT})"
    find "${TFTP_ROOT}" -type f 2>/dev/null | sort | while read -r f; do
        local rel="${f#${TFTP_ROOT}/}"
        local sz
        sz=$(stat -c '%s' "${f}" 2>/dev/null || echo "?")
        printf "  %-45s  %s bytes\n" "${rel}" "${sz}"
    done
}

cmd_add_device() {
    # Usage: pbx-tftp add-device <vendor> <mac> <extension> <password>
    local vendor="${1:?Usage: pbx-tftp add-device <vendor> <mac> <extension> <password>}"
    local mac="${2:?MAC address required (e.g. 001122aabbcc)}"
    local ext="${3:?Extension number required}"
    local pass="${4:?SIP password required}"

    # Normalize MAC — remove colons/dashes, lowercase
    mac=$(printf '%s' "${mac}" | tr -d ':-' | tr '[:upper:]' '[:lower:]')
    local outdir="${TFTP_ROOT}/${vendor}"
    mkdir -p "${outdir}"

    case "${vendor}" in
        yealink)
            local outfile="${outdir}/${mac}.cfg"
            cat > "${outfile}" << EOF
#!version:1.0.0.1
account.1.enable = 1
account.1.label = ${ext}
account.1.display_name = ${ext}
account.1.auth_name = ${ext}
account.1.user_name = ${ext}
account.1.password = ${pass}
account.1.sip_server.1.address = ${PRIMARY_IP}
account.1.sip_server.1.port = 5060
account.1.transport = 0
auto_provision.server.url = http://${PRIMARY_IP}/provisioning/
EOF
            ok "Yealink config written: ${outfile}"
            ;;
        polycom)
            local outfile="${outdir}/${mac}.cfg"
            cat > "${outfile}" << EOF
<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<PHONE_CONFIG>
  <ALL
    reg.1.address="${ext}"
    reg.1.auth.userId="${ext}"
    reg.1.auth.password="${pass}"
    reg.1.server.1.address="${PRIMARY_IP}"
    reg.1.server.1.port="5060"
  />
</PHONE_CONFIG>
EOF
            ok "Polycom config written: ${outfile}"
            ;;
        grandstream)
            local outfile="${outdir}/cfg${mac}"
            cat > "${outfile}" << EOF
<?xml version="1.0" encoding="UTF-8" ?>
<gs_provision version="1">
  <config version="1">
    <P35>${PRIMARY_IP}</P35>
    <P36>5060</P36>
    <P47>${ext}</P47>
    <P34>${ext}</P34>
    <P33>${pass}</P33>
  </config>
</gs_provision>
EOF
            ok "Grandstream config written: ${outfile}"
            ;;
        cisco)
            local outfile="${outdir}/SEP$(printf '%s' "${mac}" | tr '[:lower:]' '[:upper:]').cnf.xml"
            cat > "${outfile}" << EOF
<device>
  <line button="1">
    <featureLabel>${ext}</featureLabel>
    <name>${ext}</name>
    <authName>${ext}</authName>
    <authPassword>${pass}</authPassword>
    <proxy>${PRIMARY_IP}</proxy>
  </line>
</device>
EOF
            ok "Cisco config written: ${outfile}"
            ;;
        *)
            err "Unsupported vendor: ${vendor}. Supported: yealink, polycom, grandstream, cisco"
            exit 1
            ;;
    esac
    ok "Provision this phone by pointing it to TFTP server: ${PRIMARY_IP}"
}

cmd_set_server() {
    # Update the PBX server IP in all template files
    local new_ip="${1:-${PRIMARY_IP}}"
    hdr "Updating PBX server IP to ${new_ip} in all TFTP templates"
    local updated=0
    while IFS= read -r -d '' f; do
        if grep -qE 'PBX_IP|sip_server.*address|reg\.1\.server|<P35>' "${f}" 2>/dev/null; then
            sed -i "s|${PRIMARY_IP}|${new_ip}|g; s|PBX_IP|${new_ip}|g" "${f}" 2>/dev/null && \
                ok "  Updated: ${f#${TFTP_ROOT}/}" && updated=$((updated+1)) || true
        fi
    done < <(find "${TFTP_ROOT}" -type f -print0 2>/dev/null)
    ok "${updated} file(s) updated"
    # Restart TFTP to pick up changes
    svc_run restart || true
}

cmd_help() {
    cat << 'HELPEOF'
pbx-tftp — TFTP server management for PBX phone provisioning

Usage: pbx-tftp <command> [args]

Commands:
  status                    Show TFTP server status and file list
  start                     Start the TFTP service
  stop                      Stop the TFTP service
  restart                   Restart the TFTP service
  list                      List all files in TFTP root
  add-device <vendor> <mac> <ext> <pass>
                            Generate a device provisioning config file
                              vendor: yealink, polycom, grandstream, cisco
                              mac:    Device MAC address (any format)
                              ext:    SIP extension number
                              pass:   SIP password
  set-server [ip]           Update all templates to point to this PBX IP
                            (defaults to current PRIMARY_IP from /etc/pbx/.env)
  --help                    Show this help (-h and help accepted)
  --version                 Show version (-V accepted)

TFTP Root:      /var/lib/tftpboot
HTTP Prov Root: /var/www/apache/pbx/provisioning/

Examples:
  pbx-tftp status
  pbx-tftp add-device yealink 001122aabbcc 1001 MyPassword
  pbx-tftp add-device polycom 00:25:38:AB:CD:EF 1002 SecretPass
  pbx-tftp set-server 192.168.1.100
  pbx-tftp list
HELPEOF
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
CMD="${1:-status}"
shift 2>/dev/null || true

case "${CMD}" in
    status)           cmd_status ;;
    start)            cmd_start ;;
    stop)             cmd_stop ;;
    restart)          cmd_restart ;;
    list)             cmd_list ;;
    add-device)       cmd_add_device "$@" ;;
    set-server)       cmd_set_server "${1:-}" ;;
    help|--help|-h)   cmd_help ;;
    *)
        err "Unknown command: ${CMD}"
        cmd_help
        exit 1
        ;;
esac
