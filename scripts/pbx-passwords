#!/bin/bash
setup_output() {
    if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ] || [ "${CI:-}" = "true" ]; then
        RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
        USE_EMOJI=0
    else
        RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"; YELLOW="$(printf '\033[1;33m')"
        BLUE="$(printf '\033[0;34m')"; CYAN="$(printf '\033[0;36m')"
        BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
        USE_EMOJI=1
    fi
}
setup_output
e() { [ "$USE_EMOJI" = "1" ] && printf "%s " "$1" || true; }
ok()   { printf "%s${GREEN}%s${NC}\n" "$(e ✅)" "$*"; }
info() { printf "%s${BLUE}%s${NC}\n"  "$(e ℹ️ )" "$*"; }
warn() { printf "%s${YELLOW}%s${NC}\n" "$(e ⚠️ )" "$*"; }
err()  { printf "%s${RED}%s${NC}\n" "$(e ❌)" "$*" >&2; }
hdr()  { printf "\n${BOLD}%s%s${NC}\n" "$(e 🔧)" "$*"; }

[ -f /etc/pbx/.env ] && . /etc/pbx/.env
[ -f /root/.pbx_passwords ] && . /root/.pbx_passwords 2>/dev/null || true
[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

PW_FILE="/root/.pbx_passwords"
ENV_FILE="/etc/pbx/.env"

usage() {
    printf "Usage: pbx-passwords [options]\n\nCredential management.\n\nOptions:\n"
    printf "  (no args)              Show stored credentials (masked)\n"
    printf "  --change-admin PASS    Change FreePBX admin password\n"
    printf "  --change-mysql PASS    Change MySQL root password\n"
    printf "  --generate             Regenerate random passwords\n"
    printf "  --show-env             Show /etc/pbx/.env contents (masked)\n"
    printf "  --help/-h              Show help\n"; exit 0
}

mask() {
    local v="$1" len="${#1}"
    [ "$len" -le 4 ] && printf "****" || printf "%s****" "$(printf '%s' "$v" | cut -c1-2)"
}

gen_pw() {
    tr -dc 'A-Za-z0-9!@#%^&*' < /dev/urandom 2>/dev/null | head -c 20 2>/dev/null || \
    openssl rand -base64 20 2>/dev/null | tr -d '/+=' | head -c 20 || \
    date +%s%N | sha256sum | head -c 20
}

show_masked() {
    local file="$1"
    [ ! -f "$file" ] && { warn "File not found: $file"; return; }
    while IFS= read -r line; do
        case "$line" in
            *PASSWORD*=*|*SECRET*=*|*KEY*=*|*PASS*=*)
                KEY=$(printf '%s' "$line" | cut -d= -f1)
                VAL=$(printf '%s' "$line" | cut -d= -f2-)
                printf "%s=%s\n" "$KEY" "$(mask "$VAL")" ;;
            *) printf "%s\n" "$line" ;;
        esac
    done < "$file"
}

case "${1:-}" in
    --help|-h) usage ;;
    --change-admin)
        NP="${2:-}"; [ -z "$NP" ] && { err "--change-admin requires a PASSWORD"; exit 1; }
        command -v fwconsole >/dev/null 2>&1 || { err "fwconsole not found"; exit 1; }
        fwconsole userman --updateuser admin --password "$NP" 2>/dev/null \
            && ok "FreePBX admin password changed" || err "Failed to change admin password"
        sed -i "s/^FREEPBX_ADMIN_PASSWORD=.*/FREEPBX_ADMIN_PASSWORD='${NP}'/" "$PW_FILE" 2>/dev/null || true ;;
    --change-mysql)
        NP="${2:-}"; [ -z "$NP" ] && { err "--change-mysql requires a PASSWORD"; exit 1; }
        command -v mysql >/dev/null 2>&1 || { err "mysql not found"; exit 1; }
        MOPTS=""; [ -n "${MYSQL_ROOT_PASSWORD:-}" ] && MOPTS="-p${MYSQL_ROOT_PASSWORD}"
        # shellcheck disable=SC2086
        mysql $MOPTS -e "ALTER USER 'root'@'localhost' IDENTIFIED BY '${NP}'; FLUSH PRIVILEGES;" 2>/dev/null \
            && ok "MySQL root password changed" || err "Failed to change MySQL password"
        sed -i "s/^MYSQL_ROOT_PASSWORD=.*/MYSQL_ROOT_PASSWORD='${NP}'/" "$PW_FILE" 2>/dev/null || true ;;
    --generate)
        printf "Regenerate all PBX passwords? This updates FreePBX and MySQL. [y/N] "; read -r C
        [ "$C" != "y" ] && [ "$C" != "Y" ] && { info "Aborted."; exit 0; }
        NA=$(gen_pw); NM=$(gen_pw)
        hdr "Generated new passwords"
        printf "  FreePBX admin: %s\n" "$NA"
        printf "  MySQL root:    %s\n" "$NM"
        command -v fwconsole >/dev/null 2>&1 && \
            fwconsole userman --updateuser admin --password "$NA" 2>/dev/null || warn "Could not update FreePBX admin"
        MOPTS=""; [ -n "${MYSQL_ROOT_PASSWORD:-}" ] && MOPTS="-p${MYSQL_ROOT_PASSWORD}"
        # shellcheck disable=SC2086
        mysql $MOPTS -e "ALTER USER 'root'@'localhost' IDENTIFIED BY '${NM}'; FLUSH PRIVILEGES;" 2>/dev/null \
            || warn "Could not update MySQL"
        {
            printf "# PBX Passwords - generated %s\n" "$(date)"
            printf "FREEPBX_ADMIN_PASSWORD='%s'\n" "$NA"
            printf "MYSQL_ROOT_PASSWORD='%s'\n" "$NM"
        } > "$PW_FILE"
        chmod 600 "$PW_FILE"
        ok "Passwords saved to ${PW_FILE}" ;;
    --show-env)
        hdr "Environment: ${ENV_FILE}"
        show_masked "$ENV_FILE" ;;
    *)
        hdr "Stored Credentials: ${PW_FILE}"
        show_masked "$PW_FILE" ;;
esac
