#!/bin/bash
# pbx-passwords — PBX credential management
set -euo pipefail

if [ -n "${NO_COLOR+x}" ] || [ ! -t 1 ] || [ "${TERM:-}" = "dumb" ]; then
    RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; NC=""
else
    RED="$(printf '\033[0;31m')"; GREEN="$(printf '\033[0;32m')"
    YELLOW="$(printf '\033[1;33m')"; BLUE="$(printf '\033[0;34m')"
    CYAN="$(printf '\033[0;36m')"; BOLD="$(printf '\033[1m')"; NC="$(printf '\033[0m')"
fi

ok()   { printf "${GREEN}%s${NC}\n"   "$*"; }
info() { printf "${BLUE}%s${NC}\n"    "$*"; }
warn() { printf "${YELLOW}%s${NC}\n"  "$*"; }
err()  { printf "${RED}%s${NC}\n"     "$*" >&2; }
hdr()  { printf "\n${BOLD}%s${NC}\n" "$*"; }

set +u
[ -f /etc/pbx/.env ] && . /etc/pbx/.env 2>/dev/null || true
set -u

[ "$(id -u)" -ne 0 ] && { err "Must run as root"; exit 1; }

PW_FILE="/etc/pbx/pbx_passwords"
ENV_FILE="/etc/pbx/.env"

usage() {
    cat << 'HELPEOF'
Usage: pbx-passwords [options]

Credential management for the PBX system.

Options:
  (no args)              Show stored credentials (masked)
  --show                 Show ALL credentials unmasked (use with care!)
  --change-admin PASS    Change FreePBX admin password
  --change-mysql PASS    Change MySQL root password
  --change-avantfax PASS Change AvantFax admin password
  --generate             Regenerate all random passwords interactively
  --show-env             Show /etc/pbx/.env contents (masked)
  --help/-h              Show this help
HELPEOF
    exit 0
}

mask() {
    local v="$1" len
    len=${#v}
    [ "${len}" -le 4 ] && printf "****" && return
    printf "%s****" "$(printf '%s' "${v}" | cut -c1-2)"
}

gen_pw() {
    tr -dc 'A-Za-z0-9!@#%^&*' < /dev/urandom 2>/dev/null | head -c 20 2>/dev/null || \
    openssl rand -base64 20 2>/dev/null | tr -d '/+=' | head -c 20 || \
    date +%s%N | sha256sum | head -c 20
}

show_file() {
    local file="$1" do_mask="${2:-1}"
    [ ! -f "${file}" ] && { warn "File not found: ${file}"; return; }
    while IFS= read -r line; do
        case "${line}" in
            # KEY=value format (from .env style files)
            *PASSWORD*=*|*SECRET*=*|*_PASS*=*|*_KEY*=*)
                KEY=$(printf '%s' "${line}" | cut -d= -f1)
                VAL=$(printf '%s' "${line}" | cut -d= -f2- | tr -d "'\"")
                if [ "${do_mask}" = "1" ]; then
                    printf "  %-35s %s\n" "${KEY}" "$(mask "${VAL}")"
                else
                    printf "  %-35s %s\n" "${KEY}" "${VAL}"
                fi
                ;;
            # "Label:    value" format (human-readable credentials file)
            *Password:*|*password:*)
                LABEL=$(printf '%s' "${line}" | cut -d: -f1)
                VAL=$(printf '%s' "${line}" | cut -d: -f2- | sed 's/^[[:space:]]*//')
                if [ "${do_mask}" = "1" ]; then
                    printf "  %-30s %s\n" "${LABEL}:" "$(mask "${VAL}")"
                else
                    printf "  %-30s %s\n" "${LABEL}:" "${VAL}"
                fi
                ;;
            '#'*|'') printf "  %s\n" "${line}" ;;
            *) printf "  %s\n" "${line}" ;;
        esac
    done < "${file}"
}

case "${1:-}" in
    --help|-h) usage ;;

    --show)
        hdr "=== Credentials: ${PW_FILE} (UNMASKED) ==="
        show_file "${PW_FILE}" 0
        ;;

    --change-admin)
        NP="${2:-}"; [ -z "${NP}" ] && { err "--change-admin requires a PASSWORD argument"; exit 1; }
        UN="${FREEPBX_ADMIN_USERNAME:-admin}"
        command -v fwconsole >/dev/null 2>&1 || { err "fwconsole not found — is FreePBX installed?"; exit 1; }
        if fwconsole userman --updateuser "${UN}" --password "${NP}" 2>/dev/null; then
            ok "FreePBX password changed for user: ${UN}"
        else
            err "Failed to change FreePBX admin password"
        fi
        sed -i "s|^ADMIN_PASSWORD=.*|ADMIN_PASSWORD='${NP}'|" "${PW_FILE}" 2>/dev/null || true
        sed -i "s|^ADMIN_PASSWORD=.*|ADMIN_PASSWORD='${NP}'|" "${ENV_FILE}" 2>/dev/null || true
        ;;

    --change-mysql)
        NP="${2:-}"; [ -z "${NP}" ] && { err "--change-mysql requires a PASSWORD argument"; exit 1; }
        command -v mysql >/dev/null 2>&1 || { err "mysql not found"; exit 1; }
        MOPTS=""; [ -n "${MYSQL_ROOT_PASSWORD:-}" ] && MOPTS="-p${MYSQL_ROOT_PASSWORD}"
        # shellcheck disable=SC2086
        if mysql ${MOPTS} -e "ALTER USER 'root'@'localhost' IDENTIFIED BY '${NP}'; FLUSH PRIVILEGES;" 2>/dev/null; then
            ok "MySQL root password changed"
        else
            err "Failed to change MySQL root password"
        fi
        sed -i "s|^MYSQL_ROOT_PASSWORD=.*|MYSQL_ROOT_PASSWORD='${NP}'|" "${PW_FILE}" 2>/dev/null || true
        sed -i "s|^MYSQL_ROOT_PASSWORD=.*|MYSQL_ROOT_PASSWORD='${NP}'|" "${ENV_FILE}" 2>/dev/null || true
        ;;

    --change-avantfax)
        NP="${2:-}"; [ -z "${NP}" ] && { err "--change-avantfax requires a PASSWORD argument"; exit 1; }
        UN="${AVANTFAX_ADMIN_USERNAME:-admin}"
        command -v mysql >/dev/null 2>&1 || { err "mysql not found"; exit 1; }
        MOPTS=""; [ -n "${MYSQL_ROOT_PASSWORD:-}" ] && MOPTS="-p${MYSQL_ROOT_PASSWORD}"
        HASH=$(printf '%s' "${NP}" | md5sum | cut -c1-32)
        # shellcheck disable=SC2086
        if mysql ${MOPTS} avantfax -e \
            "UPDATE UserAccount SET password='${HASH}' WHERE username='${UN}'" 2>/dev/null; then
            ok "AvantFax password changed for user: ${UN}"
        else
            err "Failed to change AvantFax password"
        fi
        sed -i "s|^AVANTFAX_ADMIN_PASSWORD=.*|AVANTFAX_ADMIN_PASSWORD='${NP}'|" "${PW_FILE}" 2>/dev/null || true
        ;;

    --generate)
        printf "Regenerate ALL PBX passwords? This updates FreePBX and MySQL. [y/N] "
        read -r CONFIRM
        [ "${CONFIRM}" != "y" ] && [ "${CONFIRM}" != "Y" ] && { info "Aborted."; exit 0; }
        NA=$(gen_pw); NM=$(gen_pw); NAF=$(gen_pw)
        hdr "Generated new passwords"
        printf "  FreePBX admin : %s\n" "${NA}"
        printf "  MySQL root    : %s\n" "${NM}"
        printf "  AvantFax admin: %s\n" "${NAF}"
        UN="${FREEPBX_ADMIN_USERNAME:-admin}"
        command -v fwconsole >/dev/null 2>&1 && \
            fwconsole userman --updateuser "${UN}" --password "${NA}" 2>/dev/null && \
            ok "FreePBX password updated" || warn "Could not update FreePBX"
        MOPTS=""; [ -n "${MYSQL_ROOT_PASSWORD:-}" ] && MOPTS="-p${MYSQL_ROOT_PASSWORD}"
        # shellcheck disable=SC2086
        mysql ${MOPTS} -e "ALTER USER 'root'@'localhost' IDENTIFIED BY '${NM}'; FLUSH PRIVILEGES;" 2>/dev/null && \
            ok "MySQL password updated" || warn "Could not update MySQL"
        HASH=$(printf '%s' "${NAF}" | md5sum | cut -c1-32)
        # shellcheck disable=SC2086
        mysql ${MOPTS} avantfax -e \
            "UPDATE UserAccount SET password='${HASH}' WHERE username='${AVANTFAX_ADMIN_USERNAME:-admin}'" 2>/dev/null && \
            ok "AvantFax password updated" || warn "Could not update AvantFax"
        sed -i \
            -e "s|^ADMIN_PASSWORD=.*|ADMIN_PASSWORD='${NA}'|" \
            -e "s|^MYSQL_ROOT_PASSWORD=.*|MYSQL_ROOT_PASSWORD='${NM}'|" \
            -e "s|^AVANTFAX_ADMIN_PASSWORD=.*|AVANTFAX_ADMIN_PASSWORD='${NAF}'|" \
            "${PW_FILE}" "${ENV_FILE}" 2>/dev/null || true
        ok "Passwords saved to ${PW_FILE}"
        ;;

    --show-env)
        hdr "=== Environment: ${ENV_FILE} ==="
        show_file "${ENV_FILE}" 1
        ;;

    *)
        hdr "=== Credentials: ${PW_FILE} ==="
        show_file "${PW_FILE}" 1
        printf "\n  Run with --show to display unmasked values.\n\n"
        ;;
esac
